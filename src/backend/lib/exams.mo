    let sv11 = List.empty<ExamVersion>();
    let qv11 = List.empty<Question>();
    PoolV11.seedV11(sv11, qv11);
    for (q in qv11.values()) { addQuestionIfMissing(questions, q) };

    // Special exam mode version metadata (client-side builds questions from the pool)
    addVersionIfMissing(versions, { id = "ptcb-randomized"; examId = "ptcb"; versionName = "Randomized Practice"; totalQuestions = 90; scoredQuestions = 80; timeLimitMinutes = 110 });
    addVersionIfMissing(versions, { id = "ptcb-full-pool"; examId = "ptcb"; versionName = "Full Pool Exam"; totalQuestions = 0; scoredQuestions = 0; timeLimitMinutes = 110 });
