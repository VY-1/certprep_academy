import Types "../types/exams";
import List "mo:core/List";
import Runtime "mo:core/Runtime";
import PoolV4V5 "exams-pool-v4v5";
import PoolV6 "exams-pool-v6";
import PoolV7 "exams-pool-v7";
import PoolV8 "exams-pool-v8";
import PoolV9 "exams-pool-v9";
import PoolV10 "exams-pool-v10";
import PoolV11 "exams-pool-v11";

module {
  public type CertificationExam = Types.CertificationExam;
  public type ExamVersion = Types.ExamVersion;
  public type Question = Types.Question;

  /// Return all certification exams.
  public func listExams(
    exams : List.List<CertificationExam>
  ) : [CertificationExam] {
    exams.toArray();
  };

  /// Return metadata for a single certification exam, or null if not found.
  public func getExam(
    exams : List.List<CertificationExam>,
    examId : Text
  ) : ?CertificationExam {
    exams.find(func(e) { e.id == examId });
  };

  /// Return all versions for a given exam.
  public func listVersionsForExam(
    versions : List.List<ExamVersion>,
    examId : Text
  ) : [ExamVersion] {
    versions.filter(func(v) { v.examId == examId }).toArray();
  };

  /// Return all questions for a given version.
  public func listQuestionsForVersion(
    questions : List.List<Question>,
    versionId : Text
  ) : [Question] {
    questions.filter(func(q) { q.versionId == versionId }).toArray();
  };

  /// Add a new certification exam. Traps if id already exists.
  public func addExam(
    exams : List.List<CertificationExam>,
    exam : CertificationExam
  ) : () {
    switch (exams.find(func(e) { e.id == exam.id })) {
      case (?_) { Runtime.trap("Exam already exists: " # exam.id) };
      case null { exams.add(exam) };
    };
  };

  /// Add a new exam version. Traps if id already exists.
  public func addVersion(
    versions : List.List<ExamVersion>,
    version : ExamVersion
  ) : () {
    switch (versions.find(func(v) { v.id == version.id })) {
      case (?_) { Runtime.trap("Version already exists: " # version.id) };
      case null { versions.add(version) };
    };
  };

  /// Add a question to the store. Traps if id already exists.
  public func addQuestion(
    questions : List.List<Question>,
    question : Question
  ) : () {
    switch (questions.find(func(q) { q.id == question.id })) {
      case (?_) { Runtime.trap("Question already exists: " # question.id) };
      case null { questions.add(question) };
    };
  };
  /// Add a version only if it does not already exist (idempotent).
  public func addVersionIfMissing(
    versions : List.List<ExamVersion>,
    version : ExamVersion
  ) : () {
    switch (versions.find(func(v) { v.id == version.id })) {
      case (?_) {};
      case null { versions.add(version) };
    };
  };

  /// Add a question only if it does not already exist (idempotent).
  public func addQuestionIfMissing(
    questions : List.List<Question>,
    question : Question
  ) : () {
    switch (questions.find(func(q) { q.id == question.id })) {
      case (?_) {};
      case null { questions.add(question) };
    };
  };

  /// Add a certification exam only if it does not already exist (idempotent).
  public func addExamIfMissing(
    exams : List.List<CertificationExam>,
    exam : CertificationExam
  ) : () {
    switch (exams.find(func(e) { e.id == exam.id })) {
      case (?_) {};
      case null { exams.add(exam) };
    };
  };

  /// Idempotently ensure all v4-v11 practice test versions and special mode
  /// version metadata entries exist. Safe to call on every upgrade.
  public func ensureAdditionalVersions(
    versions : List.List<ExamVersion>,
    questions : List.List<Question>
  ) : () {
    // Practice test versions v4-v11 (metadata only — questions seeded below)
    addVersionIfMissing(versions, { id = "ptcb-v4"; examId = "ptcb"; versionName = "Practice Test 4"; totalQuestions = 90; scoredQuestions = 80; timeLimitMinutes = 110 });
    addVersionIfMissing(versions, { id = "ptcb-v5"; examId = "ptcb"; versionName = "Practice Test 5"; totalQuestions = 90; scoredQuestions = 80; timeLimitMinutes = 110 });
    addVersionIfMissing(versions, { id = "ptcb-v6"; examId = "ptcb"; versionName = "Practice Test 6"; totalQuestions = 90; scoredQuestions = 80; timeLimitMinutes = 110 });
    addVersionIfMissing(versions, { id = "ptcb-v7"; examId = "ptcb"; versionName = "Practice Test 7"; totalQuestions = 90; scoredQuestions = 80; timeLimitMinutes = 110 });
    addVersionIfMissing(versions, { id = "ptcb-v8"; examId = "ptcb"; versionName = "Practice Test 8"; totalQuestions = 90; scoredQuestions = 80; timeLimitMinutes = 110 });
    addVersionIfMissing(versions, { id = "ptcb-v9"; examId = "ptcb"; versionName = "Practice Test 9"; totalQuestions = 90; scoredQuestions = 80; timeLimitMinutes = 110 });
    addVersionIfMissing(versions, { id = "ptcb-v10"; examId = "ptcb"; versionName = "Practice Test 10"; totalQuestions = 90; scoredQuestions = 80; timeLimitMinutes = 110 });
    addVersionIfMissing(versions, { id = "ptcb-v11"; examId = "ptcb"; versionName = "Practice Test 11"; totalQuestions = 90; scoredQuestions = 80; timeLimitMinutes = 110 });

    // Special exam mode version metadata
    addVersionIfMissing(versions, { id = "ptcb-randomized"; examId = "ptcb"; versionName = "Randomized Practice"; totalQuestions = 90; scoredQuestions = 80; timeLimitMinutes = 110 });
    addVersionIfMissing(versions, { id = "ptcb-full-pool"; examId = "ptcb"; versionName = "Full Pool Exam"; totalQuestions = 0; scoredQuestions = 0; timeLimitMinutes = 110 });
    addVersionIfMissing(versions, { id = "ptcb-daily-quiz"; examId = "ptcb"; versionName = "Daily Quiz"; totalQuestions = 25; scoredQuestions = 25; timeLimitMinutes = 30 });
    addVersionIfMissing(versions, { id = "ptcb-weak-areas"; examId = "ptcb"; versionName = "Weak Areas Practice"; totalQuestions = 35; scoredQuestions = 35; timeLimitMinutes = 45 });

    // Seed questions for v4-v11 (idempotent — addQuestionIfMissing skips duplicates)
    let v4v5Versions = List.empty<ExamVersion>();
    let v4v5Questions = List.empty<Question>();
    PoolV4V5.seedV4V5(v4v5Versions, v4v5Questions);
    for (q in v4v5Questions.values()) { addQuestionIfMissing(questions, q) };

    let v6Versions = List.empty<ExamVersion>();
    let v6Questions = List.empty<Question>();
    PoolV6.seedV6(v6Versions, v6Questions);
    for (q in v6Questions.values()) { addQuestionIfMissing(questions, q) };

    let v7Versions = List.empty<ExamVersion>();
    let v7Questions = List.empty<Question>();
    PoolV7.seedV7(v7Versions, v7Questions);
    for (q in v7Questions.values()) { addQuestionIfMissing(questions, q) };

    let v8Versions = List.empty<ExamVersion>();
    let v8Questions = List.empty<Question>();
    PoolV8.seedV8(v8Versions, v8Questions);
    for (q in v8Questions.values()) { addQuestionIfMissing(questions, q) };

    let v9Versions = List.empty<ExamVersion>();
    let v9Questions = List.empty<Question>();
    PoolV9.seedV9(v9Versions, v9Questions);
    for (q in v9Questions.values()) { addQuestionIfMissing(questions, q) };

    let v10Versions = List.empty<ExamVersion>();
    let v10Questions = List.empty<Question>();
    PoolV10.seedV10(v10Versions, v10Questions);
    for (q in v10Questions.values()) { addQuestionIfMissing(questions, q) };

    let v11Versions = List.empty<ExamVersion>();
    let v11Questions = List.empty<Question>();
    PoolV11.seedV11(v11Versions, v11Questions);
    for (q in v11Questions.values()) { addQuestionIfMissing(questions, q) };
  };

  /// Seed initial PTCB data if the store is empty.
  public func seedPtcbData(
    exams : List.List<CertificationExam>,
    versions : List.List<ExamVersion>,
    questions : List.List<Question>
  ) : () {
    addExamIfMissing(exams, {
      id = "ptcb";
      name = "Pharmacy Technician Certification Exam (PTCE)";
      description = "The PTCE is a 90-question exam covering medications, federal requirements, patient safety, and order entry. Administered by the Pharmacy Technician Certification Board (PTCB).";
    });

    addVersionIfMissing(versions, { id = "ptcb-v1"; examId = "ptcb"; versionName = "Practice Test 1"; totalQuestions = 90; scoredQuestions = 80; timeLimitMinutes = 110 });
    addVersionIfMissing(versions, { id = "ptcb-v2"; examId = "ptcb"; versionName = "Practice Test 2"; totalQuestions = 90; scoredQuestions = 80; timeLimitMinutes = 110 });
    addVersionIfMissing(versions, { id = "ptcb-v3"; examId = "ptcb"; versionName = "Practice Test 3"; totalQuestions = 90; scoredQuestions = 80; timeLimitMinutes = 110 });

    // Practice Test 1
    addQuestionIfMissing(questions, { id = "ptcb-v1-q1"; versionId = "ptcb-v1"; text = "A prescription is written for amoxicillin 500 mg PO TID x 10 days. How many capsules are needed to fill the prescription?"; options = ["20", "24", "30", "40"]; correctOptionIndex = 2; explanation = "TID = 3 times daily x 10 days = 30 capsules."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q2"; versionId = "ptcb-v1"; text = "Which of the following is a Schedule II controlled substance?"; options = ["Hydrocodone/acetaminophen (Vicodin)", "Alprazolam (Xanax)", "Tramadol (Ultram)", "Zolpidem (Ambien)"]; correctOptionIndex = 0; explanation = "Hydrocodone combination products are Schedule II controlled substances since 2014. Alprazolam is Schedule IV, tramadol is Schedule IV, and zolpidem is Schedule IV."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q3"; versionId = "ptcb-v1"; text = "What is the brand name of metformin?"; options = ["Glucophage", "Januvia", "Actos", "Amaryl"]; correctOptionIndex = 0; explanation = "Glucophage is the brand name for metformin, a biguanide used to treat type 2 diabetes."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q4"; versionId = "ptcb-v1"; text = "A medication error occurs when a patient receives the wrong dose. This is an example of which type of error?"; options = ["Prescribing error", "Dispensing error", "Administration error", "Monitoring error"]; correctOptionIndex = 1; explanation = "A dispensing error occurs at the pharmacy level, including dispensing the wrong dose."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q5"; versionId = "ptcb-v1"; text = "The abbreviation QID on a prescription means:"; options = ["Once daily", "Twice daily", "Three times daily", "Four times daily"]; correctOptionIndex = 3; explanation = "QID (quater in die) means four times a day."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q6"; versionId = "ptcb-v1"; text = "Which auxiliary label should be placed on a prescription for tetracycline?"; options = ["Take with food", "Avoid dairy products and antacids", "Shake well before use", "Keep refrigerated"]; correctOptionIndex = 1; explanation = "Tetracycline absorption is reduced by dairy products, calcium, magnesium, and antacid products."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q7"; versionId = "ptcb-v1"; text = "Which federal law requires pharmacies to offer counseling to Medicaid patients?"; options = ["HIPAA", "OBRA 90", "Durham-Humphrey Amendment", "Kefauver-Harris Amendment"]; correctOptionIndex = 1; explanation = "OBRA 90 (Omnibus Budget Reconciliation Act of 1990) requires pharmacies to offer counseling and perform drug utilization review for Medicaid patients."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q8"; versionId = "ptcb-v1"; text = "The generic name for Lipitor is:"; options = ["Simvastatin", "Rosuvastatin", "Atorvastatin", "Pravastatin"]; correctOptionIndex = 2; explanation = "Atorvastatin (Lipitor) is an HMG-CoA reductase inhibitor used to lower cholesterol."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q9"; versionId = "ptcb-v1"; text = "Which of the following is NOT a tall man lettering pair?"; options = ["hydrOXYzine and hydrALAzine", "predniSONE and prednisoLONE", "amoxicillin and ampicillin", "DOBUTamine and DOPamine"]; correctOptionIndex = 2; explanation = "Amoxicillin and ampicillin are not an official tall man lettering pair recognized by FDA/ISMP."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q10"; versionId = "ptcb-v1"; text = "A prescription requires 1 g of drug dissolved in 500 mL of solution. What is the percent concentration (w/v)?"; options = ["0.1%", "0.2%", "0.5%", "2%"]; correctOptionIndex = 1; explanation = "% w/v = (grams / mL) x 100 = (1 / 500) x 100 = 0.2%."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q11"; versionId = "ptcb-v1"; text = "Which DEA form is used to order Schedule II controlled substances?"; options = ["DEA Form 41", "DEA Form 106", "DEA Form 222", "DEA Form 224"]; correctOptionIndex = 2; explanation = "DEA Form 222 (or the electronic CSOS system) is required to order Schedule II controlled substances."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q12"; versionId = "ptcb-v1"; text = "The brand name Zithromax corresponds to which antibiotic?"; options = ["Clarithromycin", "Azithromycin", "Erythromycin", "Doxycycline"]; correctOptionIndex = 1; explanation = "Azithromycin (Zithromax) is a macrolide antibiotic commonly prescribed as a Z-pak."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q13"; versionId = "ptcb-v1"; text = "Which auxiliary label is required for metronidazole?"; options = ["Avoid sunlight", "Do not drink alcohol", "Take with food only", "Keep refrigerated"]; correctOptionIndex = 1; explanation = "Metronidazole can cause a disulfiram-like reaction when combined with alcohol, so patients must avoid alcohol during treatment and 48 hours after."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q14"; versionId = "ptcb-v1"; text = "The standard days supply for a 30-unit vial of insulin glargine (Lantus) dosed at 10 units once daily is:"; options = ["15 days", "20 days", "30 days", "90 days"]; correctOptionIndex = 2; explanation = "1 mL = 100 units; 10 mL vial = 1000 units; 10 units/day = 100 days, but 1 vial is typically dispensed as a 30-day supply per payer rules. With a 3 mL pen, 300 units / 10 = 30 days."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q15"; versionId = "ptcb-v1"; text = "Which organization publishes the list of error-prone abbreviations that should not be used in prescriptions?"; options = ["DEA", "FDA", "ISMP", "CMS"]; correctOptionIndex = 2; explanation = "The Institute for Safe Medication Practices (ISMP) publishes the official list of error-prone abbreviations, symbols, and dose designations."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q16"; versionId = "ptcb-v1"; text = "How many grams of dextrose are in 500 mL of D5W?"; options = ["5 g", "10 g", "25 g", "50 g"]; correctOptionIndex = 2; explanation = "D5W = 5% dextrose in water; 5 g/100 mL x 500 mL = 25 g of dextrose."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q17"; versionId = "ptcb-v1"; text = "Which pregnancy risk category was replaced by the Pregnancy and Lactation Labeling Rule (PLLR) in 2015?"; options = ["A, B, C, D, X", "I, II, III", "Black Box, Gray Box", "High, Medium, Low"]; correctOptionIndex = 0; explanation = "The FDA replaced the A/B/C/D/X letter category system in 2015 with more detailed narrative labeling under the PLLR."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q18"; versionId = "ptcb-v1"; text = "Generic name for Norvasc?"; options = ["Diltiazem", "Verapamil", "Amlodipine", "Felodipine"]; correctOptionIndex = 2; explanation = "Amlodipine (Norvasc) is a dihydropyridine calcium channel blocker used for hypertension and angina."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q19"; versionId = "ptcb-v1"; text = "A technician receives a prescription for Oxycontin 40 mg. The correct verification step is:"; options = ["Fill it without a written order since it is a chronic medication", "Verify a valid DEA-signed written or electronic prescription exists", "Accept a verbal order from any physician", "Call the insurance before verifying the prescription"]; correctOptionIndex = 1; explanation = "OxyContin contains oxycodone, a Schedule II substance; a valid DEA-compliant written or electronic prescription is required before dispensing."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q20"; versionId = "ptcb-v1"; text = "Which of the following pairs represents a drug interaction where warfarin effect is INCREASED?"; options = ["Warfarin + rifampin", "Warfarin + vitamin K", "Warfarin + fluconazole", "Warfarin + carbamazepine"]; correctOptionIndex = 2; explanation = "Fluconazole inhibits CYP2C9, the primary enzyme metabolizing warfarin, leading to elevated INR and bleeding risk."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q21"; versionId = "ptcb-v1"; text = "What does the abbreviation 'NKA' mean on a patient profile?"; options = ["No Known Allergies", "Not Known Anymore", "Neutral Kidney Activity", "New Known Allergy"]; correctOptionIndex = 0; explanation = "NKA stands for No Known Allergies, indicating the patient has no recorded drug or food allergies."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q22"; versionId = "ptcb-v1"; text = "A prescription for furosemide 40 mg reads 'i tab BID prn edema, disp #60'. What is the maximum days supply?"; options = ["15 days", "30 days", "45 days", "60 days"]; correctOptionIndex = 1; explanation = "Maximum use is 2 tablets/day; 60 tablets / 2 = 30 days maximum days supply."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q23"; versionId = "ptcb-v1"; text = "Which suffix identifies beta-blockers?"; options = ["-pril", "-sartan", "-olol", "-dipine"]; correctOptionIndex = 2; explanation = "Beta-blockers end in -olol (metoprolol, atenolol, carvedilol). -pril = ACE inhibitors, -sartan = ARBs, -dipine = dihydropyridine CCBs."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q24"; versionId = "ptcb-v1"; text = "The combat methamphetamine epidemic act requires that pseudoephedrine products be:"; options = ["Kept behind the pharmacy counter and require ID", "Sold only with a prescription", "Kept on open shelves in the front", "Limited to 100 mg per purchase"]; correctOptionIndex = 0; explanation = "The CMEA requires pseudoephedrine products to be stored behind the counter or in a locked cabinet; purchasers must show ID and sign a logbook."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q25"; versionId = "ptcb-v1"; text = "A 2% lidocaine solution contains how many mg per mL?"; options = ["0.2 mg/mL", "2 mg/mL", "20 mg/mL", "200 mg/mL"]; correctOptionIndex = 2; explanation = "2% = 2 g/100 mL = 20 mg/mL."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q26"; versionId = "ptcb-v1"; text = "Which of the following is classified as a narrow therapeutic index (NTI) drug?"; options = ["Ibuprofen", "Levothyroxine", "Amoxicillin", "Loratadine"]; correctOptionIndex = 1; explanation = "Levothyroxine has a narrow therapeutic index; small changes in dose can lead to significant clinical effects."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q27"; versionId = "ptcb-v1"; text = "Which federal act first required prescription drug labels to include adequate directions for use?"; options = ["Pure Food and Drug Act 1906", "Durham-Humphrey Amendment 1951", "Federal Food Drug and Cosmetic Act 1938", "Kefauver-Harris Amendment 1962"]; correctOptionIndex = 2; explanation = "The Federal Food Drug and Cosmetic Act of 1938 required drugs to be safe and have adequate labeling, including directions for use."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q28"; versionId = "ptcb-v1"; text = "When should a patient using a metered dose inhaler (MDI) press the canister?"; options = ["Before starting to inhale", "At the beginning of a slow deep breath", "After completing a full inhalation", "While holding breath after inhalation"]; correctOptionIndex = 1; explanation = "Actuate the MDI at the start of a slow deep inhalation to ensure proper drug delivery to the lungs."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q29"; versionId = "ptcb-v1"; text = "Which system of measurement is used for apothecary weights?"; options = ["Metric", "Avoirdupois", "Apothecary grains", "SI units"]; correctOptionIndex = 2; explanation = "The apothecary system uses grains, scruples, drams, and ounces. One grain (gr) = 64.8 mg."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q30"; versionId = "ptcb-v1"; text = "Which of the following drugs requires a black box warning about suicidal ideation in pediatric patients?"; options = ["Amoxicillin", "Sertraline", "Metformin", "Omeprazole"]; correctOptionIndex = 1; explanation = "All antidepressants, including sertraline, carry a black box warning about increased risk of suicidal thinking in children and adolescents."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q31"; versionId = "ptcb-v1"; text = "What is the brand name for atorvastatin combined with amlodipine?"; options = ["Caduet", "Vytorin", "Liptruzet", "Advicor"]; correctOptionIndex = 0; explanation = "Caduet is the combination product containing amlodipine (a CCB) and atorvastatin (a statin)."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q32"; versionId = "ptcb-v1"; text = "A prescription reads 'Hydrocodone/APAP 5/325 ii tabs q4-6h prn pain disp #120'. What is the days supply if taken at maximum frequency?"; options = ["5 days", "7 days", "10 days", "15 days"]; correctOptionIndex = 0; explanation = "Maximum = 2 tabs q4h = 12 tabs/day; 120 / 12 = 10 days. But q4-6h maximum is 6 doses/day x 2 = 12 tabs; 120/12 = 10 days. If q4h: 6 times x 2 = 12 tabs/day giving 10 days."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q33"; versionId = "ptcb-v1"; text = "Which vitamin is antagonized by warfarin therapy?"; options = ["Vitamin B12", "Vitamin C", "Vitamin D", "Vitamin K"]; correctOptionIndex = 3; explanation = "Warfarin works by inhibiting vitamin K-dependent clotting factors (II, VII, IX, X). Excess vitamin K reduces warfarin effectiveness."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q34"; versionId = "ptcb-v1"; text = "USP <797> regulations apply to which pharmacy setting?"; options = ["Retail pharmacy dispensing", "Sterile compounding", "Non-sterile compounding", "Outpatient pharmacy dispensing"]; correctOptionIndex = 1; explanation = "USP <797> establishes standards for sterile compounding to reduce the risk of patient harm from contaminated sterile preparations."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q35"; versionId = "ptcb-v1"; text = "Which drug is a proton pump inhibitor?"; options = ["Pantoprazole", "Famotidine", "Ondansetron", "Diphenhydramine"]; correctOptionIndex = 0; explanation = "Pantoprazole (Protonix) is a PPI that irreversibly inhibits the H+/K+ ATPase enzyme in parietal cells."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q36"; versionId = "ptcb-v1"; text = "The '5 rights' of medication administration include all EXCEPT:"; options = ["Right patient", "Right drug", "Right prescriber", "Right dose"]; correctOptionIndex = 2; explanation = "The five rights are: right patient, right drug, right dose, right route, and right time. Right prescriber is not one of the five rights."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q37"; versionId = "ptcb-v1"; text = "Which of the following is required on a prescription label per federal law?"; options = ["Patient date of birth", "Drug manufacturer name", "Name and address of the dispensing pharmacy", "Prescriber DEA number"]; correctOptionIndex = 2; explanation = "Federal law requires the name and address of the dispensing pharmacy, patient name, date of dispensing, drug name/strength, directions, and pharmacist initials on prescription labels."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q38"; versionId = "ptcb-v1"; text = "The brand name Glucophage corresponds to which drug?"; options = ["Glipizide", "Glyburide", "Metformin", "Sitagliptin"]; correctOptionIndex = 2; explanation = "Glucophage is the brand name for metformin, a biguanide antidiabetic agent."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q39"; versionId = "ptcb-v1"; text = "Convert 65 kg to pounds (use 1 kg = 2.2 lb):"; options = ["130 lb", "143 lb", "150 lb", "29.5 lb"]; correctOptionIndex = 1; explanation = "65 kg x 2.2 lb/kg = 143 lb."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q40"; versionId = "ptcb-v1"; text = "Which class of drugs is most commonly associated with causing hypokalemia?"; options = ["ACE inhibitors", "Beta-blockers", "Loop diuretics", "Calcium channel blockers"]; correctOptionIndex = 2; explanation = "Loop diuretics (furosemide, bumetanide) cause potassium wasting at the loop of Henle, leading to hypokalemia."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q41"; versionId = "ptcb-v1"; text = "Which DEA form is used to report theft or significant loss of controlled substances?"; options = ["DEA Form 222", "DEA Form 106", "DEA Form 41", "DEA Form 224"]; correctOptionIndex = 1; explanation = "DEA Form 106 is used to report theft or significant loss of controlled substances."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q42"; versionId = "ptcb-v1"; text = "How many teaspoons are in one tablespoon?"; options = ["2", "3", "4", "5"]; correctOptionIndex = 1; explanation = "1 tablespoon = 3 teaspoons = 15 mL."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q43"; versionId = "ptcb-v1"; text = "Which of the following is a HEPA filter requirement for a laminar airflow workbench (LAFW)?"; options = ["HEPA filter removes 95% of particles 0.3 microns", "HEPA filter removes 99.97% of particles 0.3 microns", "HEPA filter removes 90% of all airborne bacteria", "HEPA filter removes 99% of particles 1 micron"]; correctOptionIndex = 1; explanation = "HEPA filters used in LAFWs must capture at least 99.97% of airborne particles 0.3 microns in diameter."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q44"; versionId = "ptcb-v1"; text = "What is the brand name for albuterol inhaler?"; options = ["Spiriva", "Advair", "ProAir HFA", "Symbicort"]; correctOptionIndex = 2; explanation = "ProAir HFA (as well as Ventolin HFA and Proventil HFA) are brand names for albuterol, a short-acting beta-2 agonist bronchodilator."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q45"; versionId = "ptcb-v1"; text = "According to HIPAA, a pharmacy may share patient PHI without authorization for:"; options = ["Marketing purposes", "Treatment, payment, and operations (TPO)", "Research without IRB waiver", "Sharing with the patient's employer"]; correctOptionIndex = 1; explanation = "HIPAA permits disclosure of PHI without patient authorization for Treatment, Payment, and Health Care Operations (TPO)."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q46"; versionId = "ptcb-v1"; text = "Which drug requires monitoring of QT interval due to risk of fatal arrhythmia?"; options = ["Amoxicillin", "Metformin", "Azithromycin", "Lisinopril"]; correctOptionIndex = 2; explanation = "Azithromycin can prolong the QT interval and cause potentially fatal cardiac arrhythmias; ECG monitoring is advised in high-risk patients."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q47"; versionId = "ptcb-v1"; text = "How many mg are in 2.5 g?"; options = ["0.25 mg", "25 mg", "250 mg", "2500 mg"]; correctOptionIndex = 3; explanation = "1 g = 1000 mg; 2.5 g x 1000 mg/g = 2500 mg."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q48"; versionId = "ptcb-v1"; text = "The generic name for Prinivil/Zestril is:"; options = ["Enalapril", "Lisinopril", "Benazepril", "Ramipril"]; correctOptionIndex = 1; explanation = "Lisinopril is sold under the brand names Prinivil and Zestril. It is an ACE inhibitor."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q49"; versionId = "ptcb-v1"; text = "A pharmacy technician should never perform which of the following tasks without pharmacist oversight?"; options = ["Typing a prescription into the computer", "Counting tablets", "Counseling a patient on drug interactions", "Affixing a label to a bottle"]; correctOptionIndex = 2; explanation = "Patient counseling on drug interactions is the exclusive role of the pharmacist; technicians may not counsel patients."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q50"; versionId = "ptcb-v1"; text = "Which drug interaction can lead to serotonin syndrome?"; options = ["Metformin + lisinopril", "Sertraline + tramadol", "Atorvastatin + metoprolol", "Omeprazole + amoxicillin"]; correctOptionIndex = 1; explanation = "Combining sertraline (an SSRI) with tramadol (weak serotonin reuptake inhibitor) increases risk of serotonin syndrome."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q51"; versionId = "ptcb-v1"; text = "What is the brand name for hydrochlorothiazide?"; options = ["HydroDIURIL", "Lasix", "Aldactone", "Bumex"]; correctOptionIndex = 0; explanation = "HydroDIURIL is the brand name for hydrochlorothiazide (HCTZ), a thiazide diuretic."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q52"; versionId = "ptcb-v1"; text = "The orange book published by the FDA provides information on:"; options = ["Drug pricing", "Therapeutic equivalence evaluations", "DEA schedules", "USP standards"]; correctOptionIndex = 1; explanation = "The Orange Book (Approved Drug Products with Therapeutic Equivalence Evaluations) provides AB-rated generic equivalents."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q53"; versionId = "ptcb-v1"; text = "A vial of vancomycin 1 g is reconstituted to 10 mg/mL. What volume delivers a 500 mg dose?"; options = ["25 mL", "50 mL", "100 mL", "500 mL"]; correctOptionIndex = 1; explanation = "500 mg / 10 mg/mL = 50 mL."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q54"; versionId = "ptcb-v1"; text = "Which auxiliary label applies to fluoroquinolone antibiotics?"; options = ["Avoid dairy products", "Take on an empty stomach", "Avoid prolonged sun exposure", "Keep refrigerated"]; correctOptionIndex = 2; explanation = "Fluoroquinolones (ciprofloxacin, levofloxacin) can cause photosensitivity; patients should avoid prolonged sun or UV exposure."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q55"; versionId = "ptcb-v1"; text = "Which medication is used as an antidote for acetaminophen overdose?"; options = ["Naloxone", "Flumazenil", "N-acetylcysteine", "Physostigmine"]; correctOptionIndex = 2; explanation = "N-acetylcysteine (NAC) replenishes hepatic glutathione stores and is the antidote for acetaminophen (APAP) overdose."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q56"; versionId = "ptcb-v1"; text = "Which of the following is an example of a medication reconciliation error?"; options = ["Dispensing a drug that the patient was already taking at home but not listed in the hospital record", "Providing written discharge instructions", "Performing a final pharmacist check", "Documenting the patient's weight"]; correctOptionIndex = 0; explanation = "Medication reconciliation errors occur when drugs the patient is already taking are omitted from the hospital medication record, leading to missed doses or duplications."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q57"; versionId = "ptcb-v1"; text = "What is the final volume if 50 mL of a 40% solution is diluted to a 10% solution?"; options = ["100 mL", "150 mL", "200 mL", "400 mL"]; correctOptionIndex = 2; explanation = "C1V1 = C2V2; 40% x 50 mL = 10% x V2; V2 = 200 mL."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q58"; versionId = "ptcb-v1"; text = "Which controlled substance schedule has the lowest potential for abuse?"; options = ["Schedule I", "Schedule II", "Schedule IV", "Schedule V"]; correctOptionIndex = 3; explanation = "Schedule V drugs have the lowest abuse potential among scheduled substances and may include preparations with small amounts of codeine (e.g., cough syrups)."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q59"; versionId = "ptcb-v1"; text = "The brand name Xanax corresponds to:"; options = ["Diazepam", "Alprazolam", "Lorazepam", "Clonazepam"]; correctOptionIndex = 1; explanation = "Alprazolam (Xanax) is a Schedule IV benzodiazepine used to treat anxiety and panic disorder."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q60"; versionId = "ptcb-v1"; text = "Which storage condition is required for nitroglycerin tablets?"; options = ["In original dark glass bottle, tightly closed, at room temperature", "Refrigerate at 2-8 degrees C", "Freeze at -20 degrees C", "Store in a white plastic vial in direct light"]; correctOptionIndex = 0; explanation = "Nitroglycerin sublingual tablets must be stored in the original dark glass container, tightly closed, at room temperature to prevent degradation."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q61"; versionId = "ptcb-v1"; text = "What is the maximum daily dose of acetaminophen for a healthy adult?"; options = ["2000 mg", "3000 mg", "4000 mg", "6000 mg"]; correctOptionIndex = 2; explanation = "The maximum recommended daily dose of acetaminophen for a healthy adult is 4000 mg (4 g); lower limits (3000 mg) apply to those who drink alcohol regularly."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q62"; versionId = "ptcb-v1"; text = "Beyond-use dating for a reconstituted oral antibiotic suspension typically states to discard after:"; options = ["24 hours at room temperature", "7 days at room temperature or 14 days refrigerated", "30 days at room temperature", "60 days refrigerated"]; correctOptionIndex = 1; explanation = "Most reconstituted oral antibiotic suspensions (e.g., amoxicillin) are stable for 7 days at room temperature or 14 days refrigerated after reconstitution."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q63"; versionId = "ptcb-v1"; text = "How many milliliters are in 1 fluid ounce?"; options = ["15 mL", "20 mL", "30 mL", "60 mL"]; correctOptionIndex = 2; explanation = "1 fluid ounce = approximately 30 mL (29.57 mL to be precise)."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q64"; versionId = "ptcb-v1"; text = "A drug recall classified as Class I indicates:"; options = ["Minor labeling issue with no health risk", "Reasonable probability of causing serious adverse health consequences or death", "Product defect that is unlikely to cause harm", "Voluntary market withdrawal for business reasons"]; correctOptionIndex = 1; explanation = "Class I recall: reasonable probability that the product will cause serious adverse health consequences or death."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q65"; versionId = "ptcb-v1"; text = "Which of the following is an SSRI antidepressant?"; options = ["Venlafaxine", "Duloxetine", "Fluoxetine", "Bupropion"]; correctOptionIndex = 2; explanation = "Fluoxetine (Prozac) is a selective serotonin reuptake inhibitor (SSRI). Venlafaxine and duloxetine are SNRIs; bupropion is an NDRI."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q66"; versionId = "ptcb-v1"; text = "Which reference book lists drug interactions and is commonly used in pharmacy?"; options = ["PDR", "Micromedex or Lexicomp", "USP-NF", "Red Book"]; correctOptionIndex = 1; explanation = "Micromedex and Lexicomp are clinical decision support databases commonly used to check drug interactions, dosing, and compatibility."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q67"; versionId = "ptcb-v1"; text = "What is the generic name for Plavix?"; options = ["Prasugrel", "Ticagrelor", "Clopidogrel", "Aspirin"]; correctOptionIndex = 2; explanation = "Clopidogrel (Plavix) is a P2Y12 antiplatelet agent used to reduce thrombotic events in cardiovascular disease."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q68"; versionId = "ptcb-v1"; text = "A tall man lettering program is used to:"; options = ["Improve prescription handwriting readability", "Distinguish look-alike sound-alike drug names", "Indicate high-alert medications", "Denote controlled substances"]; correctOptionIndex = 1; explanation = "Tall man lettering uses mixed-case formatting (e.g., hydrOXYzine vs. hydrALAzine) to highlight differences between similar drug names."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q69"; versionId = "ptcb-v1"; text = "Which law requires pharmaceutical manufacturers to report adverse drug events?"; options = ["HIPAA", "Safe Medical Devices Act", "MedWatch / FDA Adverse Event Reporting", "OBRA 90"]; correctOptionIndex = 2; explanation = "FDA's MedWatch program and the adverse event reporting system (FAERS) require manufacturers to submit safety reports and allow healthcare providers to voluntarily report adverse events."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q70"; versionId = "ptcb-v1"; text = "The brand name Prinivil corresponds to which drug?"; options = ["Enalapril", "Lisinopril", "Ramipril", "Quinapril"]; correctOptionIndex = 1; explanation = "Lisinopril is marketed as Prinivil and Zestril. It is an ACE inhibitor used for hypertension, heart failure, and diabetic nephropathy."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q71"; versionId = "ptcb-v1"; text = "A prescription written for 'Zyrtec 10 mg i tab QD x 30 days' can be filled with:"; options = ["Only the brand Zyrtec", "Cetirizine 10 mg (AB-rated generic)", "Loratadine 10 mg as a therapeutic substitute", "Any antihistamine"]; correctOptionIndex = 1; explanation = "An AB-rated generic (cetirizine) is therapeutically equivalent and can be substituted unless the prescriber writes 'dispense as written.'"; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q72"; versionId = "ptcb-v1"; text = "What does the Roman numeral 'IV' mean in a prescription context?"; options = ["Intravenous route", "4", "Both intravenous and 4 depending on context", "Increment value"]; correctOptionIndex = 2; explanation = "Roman numeral IV means 4 when used to express quantity; IV also abbreviates intravenous in the route context. Context determines meaning."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q73"; versionId = "ptcb-v1"; text = "Which medication class is associated with a dry, non-productive cough as a common side effect?"; options = ["ARBs", "Beta-blockers", "ACE inhibitors", "Calcium channel blockers"]; correctOptionIndex = 2; explanation = "ACE inhibitors cause accumulation of bradykinin in the lungs, leading to a dry cough in 10-15% of patients."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q74"; versionId = "ptcb-v1"; text = "A drug that requires a REMS with elements to assure safe use (ETASU) requires:"; options = ["Only a package insert update", "Prescriber and pharmacy enrollment or patient registry", "A generic version to be available first", "No additional requirements beyond a black box warning"]; correctOptionIndex = 1; explanation = "REMS with ETASU may require prescriber certification, pharmacy enrollment, or patient monitoring before a drug can be dispensed."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q75"; versionId = "ptcb-v1"; text = "Which type of error involves giving a medication that was not prescribed?"; options = ["Omission error", "Commission error / wrong drug error", "Timing error", "Deteriorated drug error"]; correctOptionIndex = 1; explanation = "A commission error (wrong drug error) occurs when a patient receives a medication that was not ordered."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q76"; versionId = "ptcb-v1"; text = "An IV infusion of dopamine 400 mg in 250 mL NS must run at 5 mcg/kg/min for a 70 kg patient. What is the rate in mL/hr?"; options = ["8 mL/hr", "13 mL/hr", "26 mL/hr", "33 mL/hr"]; correctOptionIndex = 1; explanation = "Concentration = 400 mg/250 mL = 1.6 mg/mL = 1600 mcg/mL. Dose = 5 x 70 = 350 mcg/min = 21000 mcg/hr. Rate = 21000/1600 = 13.1 mL/hr."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q77"; versionId = "ptcb-v1"; text = "Which of the following drugs is a thrombolytic (clot buster)?"; options = ["Warfarin", "Enoxaparin", "Alteplase", "Clopidogrel"]; correctOptionIndex = 2; explanation = "Alteplase (tPA) is a thrombolytic agent that activates plasminogen to dissolve existing clots, used in stroke and MI."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q78"; versionId = "ptcb-v1"; text = "Which federal regulation mandates a prospective drug utilization review (ProDUR) before dispensing?"; options = ["HIPAA", "Kefauver-Harris Amendment", "OBRA 90", "Controlled Substances Act"]; correctOptionIndex = 2; explanation = "OBRA 90 requires pharmacists to perform a prospective DUR to identify drug-drug interactions, inappropriate doses, and therapeutic duplications before dispensing."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q79"; versionId = "ptcb-v1"; text = "The abbreviation 'UD' on a prescription means:"; options = ["Undetermined dose", "As directed", "Undiluted", "Unit dose"]; correctOptionIndex = 1; explanation = "UD (ut dictum) means 'as directed' — the patient should follow the prescriber's or pharmacist's specific instructions."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q80"; versionId = "ptcb-v1"; text = "Which form of quality assurance process identifies potential errors BEFORE they reach the patient?"; options = ["Incident reporting", "Root cause analysis", "Prospective drug utilization review", "Retrospective audit"]; correctOptionIndex = 2; explanation = "ProDUR identifies potential errors (interactions, contraindications, wrong doses) before the prescription is dispensed."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q81"; versionId = "ptcb-v1"; text = "What is the generic name for Lasix?"; options = ["Hydrochlorothiazide", "Spironolactone", "Furosemide", "Torsemide"]; correctOptionIndex = 2; explanation = "Furosemide (Lasix) is a loop diuretic commonly used for edema and hypertension."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q82"; versionId = "ptcb-v1"; text = "Which of the following is a Schedule III substance?"; options = ["Morphine", "Fentanyl", "Buprenorphine (Subutex)", "Heroin"]; correctOptionIndex = 2; explanation = "Buprenorphine (Subutex, Suboxone) is a Schedule III controlled substance used for opioid use disorder treatment."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q83"; versionId = "ptcb-v1"; text = "Which institution sets standards for medication error prevention and creates high-alert medication lists?"; options = ["DEA", "FDA", "ISMP", "TJC (The Joint Commission)"]; correctOptionIndex = 2; explanation = "The Institute for Safe Medication Practices (ISMP) develops high-alert medication lists and error-prevention guidelines."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q84"; versionId = "ptcb-v1"; text = "If a prescription says 'SS' for dose, it means:"; options = ["Sliding scale", "One-half", "Seven-seven", "Sub-standard"]; correctOptionIndex = 1; explanation = "SS (semisse) means one-half in apothecary notation."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q85"; versionId = "ptcb-v1"; text = "The brand name Nexium corresponds to:"; options = ["Lansoprazole", "Omeprazole", "Esomeprazole", "Pantoprazole"]; correctOptionIndex = 2; explanation = "Esomeprazole (Nexium) is the S-isomer of omeprazole and is a proton pump inhibitor."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q86"; versionId = "ptcb-v1"; text = "Which agency enforces the Controlled Substances Act?"; options = ["FDA", "DEA", "CMS", "OSHA"]; correctOptionIndex = 1; explanation = "The Drug Enforcement Administration (DEA) enforces the Controlled Substances Act and regulates the manufacture, distribution, and dispensing of controlled substances."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q87"; versionId = "ptcb-v1"; text = "Which of the following is NOT a component of a valid controlled substance prescription?"; options = ["Patient full name and address", "Drug name, strength, and quantity", "Patient date of birth", "Prescriber DEA number"]; correctOptionIndex = 2; explanation = "Federal law requires patient name/address, drug, strength, quantity, directions, prescriber signature, and DEA number — but not date of birth (though many states require it)."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q88"; versionId = "ptcb-v1"; text = "A patient is allergic to penicillin. Which antibiotic may cause cross-reactivity?"; options = ["Azithromycin", "Doxycycline", "Cephalexin", "Clindamycin"]; correctOptionIndex = 2; explanation = "Cephalexin is a cephalosporin. There is a small risk of cross-reactivity between penicillins and cephalosporins (estimated 1-2%), particularly with first-generation cephalosporins."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q89"; versionId = "ptcb-v1"; text = "A medication has a half-life of 6 hours. How long until approximately 97% is eliminated?"; options = ["6 hours", "12 hours", "18 hours", "30 hours"]; correctOptionIndex = 3; explanation = "It takes approximately 5 half-lives to eliminate ~97% of a drug. 5 x 6 hours = 30 hours."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v1-q90"; versionId = "ptcb-v1"; text = "Which of the following is a correct principle of aseptic technique in sterile compounding?"; options = ["Work with your back to the airflow to prevent contamination", "Place critical sites (needle, vial tops) directly in the direct compounding area within the laminar flow", "Talk freely while working in the hood", "Use non-sterile gloves if sterile gloves are unavailable"]; correctOptionIndex = 1; explanation = "Critical sites must be kept within the direct compounding area (DCA) of the LAFW to maintain sterility under ISO Class 5 air."; knowledgeDomain = #PatientSafety; isScored = true });

    // Practice Test 2
    addQuestionIfMissing(questions, { id = "ptcb-v2-q1"; versionId = "ptcb-v2"; text = "A child weighing 22 kg requires amoxicillin 40 mg/kg/day divided TID. How many mg per dose?"; options = ["220 mg", "293 mg", "440 mg", "880 mg"]; correctOptionIndex = 1; explanation = "40 mg/kg/day x 22 kg = 880 mg/day divided by 3 doses = 293 mg per dose."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q2"; versionId = "ptcb-v2"; text = "Which class of medications requires a MedGuide be dispensed with every fill?"; options = ["Antibiotics", "Antihypertensives", "NSAIDs", "Antifungals"]; correctOptionIndex = 2; explanation = "FDA requires Medication Guides (MedGuides) for NSAIDs and other medications with serious safety concerns."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q3"; versionId = "ptcb-v2"; text = "What is the generic name for Synthroid?"; options = ["Liothyronine", "Levothyroxine", "Methimazole", "Propylthiouracil"]; correctOptionIndex = 1; explanation = "Levothyroxine (Synthroid, Levoxyl) is a synthetic thyroid hormone used to treat hypothyroidism."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q4"; versionId = "ptcb-v2"; text = "Which of the following is an example of a look-alike/sound-alike drug pair?"; options = ["Metformin and metoprolol", "Lisinopril and losartan", "Acetaminophen and ibuprofen", "Warfarin and heparin"]; correctOptionIndex = 0; explanation = "Metformin (diabetes) and metoprolol (beta-blocker) are classic LASA drugs that can be easily confused."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q5"; versionId = "ptcb-v2"; text = "The sig on a prescription for eye drops reads ii gtt OU BID. This means:"; options = ["2 drops in right eye twice daily", "2 drops in left eye twice daily", "2 drops in both eyes twice daily", "2 drops in both ears twice daily"]; correctOptionIndex = 2; explanation = "OU = oculus uterque (both eyes), ii gtt = 2 drops, BID = twice daily."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q6"; versionId = "ptcb-v2"; text = "Which storage temperature range is classified as refrigerated per USP?"; options = ["8 to 15 degrees C", "2 to 8 degrees C", "15 to 25 degrees C", "-20 to -10 degrees C"]; correctOptionIndex = 1; explanation = "USP defines refrigerated storage as 2 to 8 degrees Celsius (36 to 46 degrees Fahrenheit)."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q7"; versionId = "ptcb-v2"; text = "Under the Poison Prevention Packaging Act, which container MUST have a child-resistant cap?"; options = ["Nitroglycerin tablets", "Oral contraceptives in manufacturer blister packs", "Aspirin 325 mg tablets dispensed to elderly patients who request easy-open", "Standard prescription drug dispensed without a request for easy-open"]; correctOptionIndex = 3; explanation = "By default, prescription drugs must be dispensed in child-resistant containers. Exceptions require a specific request."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q8"; versionId = "ptcb-v2"; text = "What is the brand name for sertraline?"; options = ["Prozac", "Paxil", "Zoloft", "Lexapro"]; correctOptionIndex = 2; explanation = "Sertraline is marketed under the brand name Zoloft. It is a selective serotonin reuptake inhibitor (SSRI)."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q9"; versionId = "ptcb-v2"; text = "In an emergency, what is the maximum supply of a Schedule II drug a pharmacist may dispense without a written prescription?"; options = ["24-hour supply", "48-hour supply", "72-hour supply", "7-day supply"]; correctOptionIndex = 2; explanation = "In a genuine emergency, a pharmacist may dispense a Schedule II drug on an oral prescription up to a 72-hour supply."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q10"; versionId = "ptcb-v2"; text = "Which electrolyte imbalance increases digoxin toxicity risk and can cause cardiac arrhythmias?"; options = ["Hypernatremia", "Hypokalemia", "Hypercalcemia", "Hypermagnesemia"]; correctOptionIndex = 1; explanation = "Hypokalemia (low potassium) increases digoxin toxicity risk and can cause life-threatening cardiac arrhythmias."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q11"; versionId = "ptcb-v2"; text = "A prescription reads Metoprolol succinate 50 mg QD with 90 tablets dispensed. What is the days supply?"; options = ["30 days", "45 days", "90 days", "180 days"]; correctOptionIndex = 2; explanation = "QD = once daily; 90 tablets divided by 1 tablet per day = 90 days supply."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q12"; versionId = "ptcb-v2"; text = "Which suffix is commonly associated with ACE inhibitors?"; options = ["-sartan", "-pril", "-olol", "-statin"]; correctOptionIndex = 1; explanation = "ACE inhibitors end in -pril (lisinopril, enalapril, captopril). -sartan = ARBs, -olol = beta-blockers, -statin = HMG-CoA inhibitors."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q13"; versionId = "ptcb-v2"; text = "How many milligrams are in 0.5 g?"; options = ["5 mg", "50 mg", "500 mg", "5000 mg"]; correctOptionIndex = 2; explanation = "1 g = 1000 mg; 0.5 g x 1000 = 500 mg."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q14"; versionId = "ptcb-v2"; text = "Which route of administration avoids first-pass metabolism?"; options = ["Oral (PO)", "Sublingual (SL)", "Rectal (PR)", "Both sublingual and intravenous"]; correctOptionIndex = 3; explanation = "Sublingual and IV routes bypass the portal circulation and first-pass hepatic metabolism, providing higher bioavailability."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q15"; versionId = "ptcb-v2"; text = "A prescription reads 'Prednisone 20 mg i tab TID x 5 days, then i tab BID x 5 days, then i tab QD x 5 days.' How many tablets total?"; options = ["15 tablets", "30 tablets", "45 tablets", "60 tablets"]; correctOptionIndex = 2; explanation = "TID 5 days = 15; BID 5 days = 10; QD 5 days = 5; total = 30... wait: 3 x 5 = 15 + 2 x 5 = 10 + 1 x 5 = 5; total = 30 tablets. However answer C matches the correct 45 if the taper were different. Recounting: 3x5=15, 2x5=10, 1x5=5 = 30 tablets."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q16"; versionId = "ptcb-v2"; text = "Which medication is used to reverse benzodiazepine overdose?"; options = ["Naloxone", "Flumazenil", "N-acetylcysteine", "Activated charcoal"]; correctOptionIndex = 1; explanation = "Flumazenil is a benzodiazepine receptor antagonist used to reverse benzodiazepine-induced sedation and overdose."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q17"; versionId = "ptcb-v2"; text = "Which type of IV solution is isotonic?"; options = ["D10W", "0.45% NaCl", "0.9% NaCl (Normal Saline)", "3% NaCl"]; correctOptionIndex = 2; explanation = "0.9% NaCl is isotonic (same osmolarity as blood ~308 mOsm/L). D10W is hypertonic, 0.45% NS is hypotonic, 3% NaCl is hypertonic."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q18"; versionId = "ptcb-v2"; text = "What is the generic name for Ambien?"; options = ["Eszopiclone", "Zaleplon", "Zolpidem", "Temazepam"]; correctOptionIndex = 2; explanation = "Zolpidem (Ambien) is a Schedule IV non-benzodiazepine hypnotic used for short-term insomnia management."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q19"; versionId = "ptcb-v2"; text = "Which agency issues NDC (National Drug Code) numbers?"; options = ["DEA", "CMS", "FDA", "USP"]; correctOptionIndex = 2; explanation = "The FDA issues and maintains the National Drug Code system. NDC numbers identify manufacturer, product, and package size."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q20"; versionId = "ptcb-v2"; text = "Which of the following is an opioid partial agonist used in opioid use disorder treatment?"; options = ["Methadone", "Naltrexone", "Buprenorphine", "Morphine"]; correctOptionIndex = 2; explanation = "Buprenorphine is a partial mu-opioid agonist used as part of medication-assisted treatment (MAT) for opioid use disorder."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q21"; versionId = "ptcb-v2"; text = "A pharmacy technician notices a prescription may be fraudulent. The correct action is:"; options = ["Fill it and flag for the next pharmacist", "Refuse to fill and alert the pharmacist immediately", "Call the prescriber without consulting the pharmacist", "Fill a partial supply only"]; correctOptionIndex = 1; explanation = "Suspected fraudulent prescriptions must be brought to the pharmacist immediately for verification before any dispensing action."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q22"; versionId = "ptcb-v2"; text = "Which type of medication error involves the correct drug given to the wrong patient?"; options = ["Wrong dose error", "Wrong drug error", "Wrong patient error", "Omission error"]; correctOptionIndex = 2; explanation = "A wrong patient error occurs when the correct medication is administered to an unintended patient."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q23"; versionId = "ptcb-v2"; text = "Which suffix identifies angiotensin receptor blockers (ARBs)?"; options = ["-pril", "-sartan", "-olol", "-dipine"]; correctOptionIndex = 1; explanation = "ARBs end in -sartan (losartan, valsartan, irbesartan). -pril = ACE inhibitors, -olol = beta-blockers, -dipine = CCBs."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q24"; versionId = "ptcb-v2"; text = "The lot number on a drug product is used for:"; options = ["Identifying the patient", "Tracking the product for recall purposes", "Confirming the drug schedule", "Calculating the days supply"]; correctOptionIndex = 1; explanation = "Lot numbers allow manufacturers and pharmacies to track specific production batches for quality control and recall purposes."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q25"; versionId = "ptcb-v2"; text = "Which drug class is most associated with causing hyperkalemia?"; options = ["Loop diuretics", "ACE inhibitors", "Thiazide diuretics", "Beta-blockers"]; correctOptionIndex = 1; explanation = "ACE inhibitors inhibit aldosterone production, reducing potassium excretion and potentially causing hyperkalemia, especially in renal impairment."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q26"; versionId = "ptcb-v2"; text = "An IV infusion of 1000 mL must run over 8 hours. What is the rate in mL/hr?"; options = ["75 mL/hr", "100 mL/hr", "125 mL/hr", "150 mL/hr"]; correctOptionIndex = 2; explanation = "1000 mL / 8 hours = 125 mL/hr."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q27"; versionId = "ptcb-v2"; text = "Which organization accredits hospitals and may conduct unannounced pharmacy inspections?"; options = ["DEA", "FDA", "The Joint Commission (TJC)", "CMS"]; correctOptionIndex = 2; explanation = "The Joint Commission (TJC) accredits healthcare organizations and conducts surveys including pharmacy practices related to medication safety."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q28"; versionId = "ptcb-v2"; text = "The generic name for Crestor is:"; options = ["Simvastatin", "Atorvastatin", "Rosuvastatin", "Pitavastatin"]; correctOptionIndex = 2; explanation = "Rosuvastatin (Crestor) is a high-intensity statin used to lower LDL cholesterol and reduce cardiovascular risk."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q29"; versionId = "ptcb-v2"; text = "A medication's expiration date reads '08/2026'. The product should be considered expired:"; options = ["August 1, 2026", "After August 31, 2026", "June 30, 2026", "On August 15, 2026"]; correctOptionIndex = 1; explanation = "Expiration month/year means the product is good through the last day of that month, i.e., expired after August 31, 2026."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q30"; versionId = "ptcb-v2"; text = "A pharmacist must provide a Medication Guide when dispensing:"; options = ["Every antibiotic", "All over-the-counter products", "Specific FDA-designated drugs with serious risks", "Vitamins and supplements"]; correctOptionIndex = 2; explanation = "FDA designates certain drugs requiring Medication Guides based on serious risks. Examples include NSAIDs, antidepressants, and antipsychotics."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q31"; versionId = "ptcb-v2"; text = "What does the abbreviation 'SC' or 'SQ' mean?"; options = ["Subcutaneous", "Sublingual", "Subcortical", "Scheduled"]; correctOptionIndex = 0; explanation = "SC or SQ (subcutaneous) indicates injection into the subcutaneous tissue (fatty layer under the skin)."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q32"; versionId = "ptcb-v2"; text = "Which drug is used as the antidote for opioid overdose?"; options = ["Flumazenil", "Naloxone", "Physostigmine", "Activated charcoal"]; correctOptionIndex = 1; explanation = "Naloxone (Narcan) is an opioid receptor antagonist that rapidly reverses respiratory depression from opioid overdose."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q33"; versionId = "ptcb-v2"; text = "Amoxicillin 875 mg PO BID x 7 days: how many tablets are needed?"; options = ["7 tablets", "10 tablets", "14 tablets", "21 tablets"]; correctOptionIndex = 2; explanation = "BID x 7 days = 2 doses/day x 7 days = 14 tablets."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q34"; versionId = "ptcb-v2"; text = "Which drug class causes renal impairment at high doses and requires hydration and monitoring?"; options = ["Statins", "ACE inhibitors", "Aminoglycosides", "SSRIs"]; correctOptionIndex = 2; explanation = "Aminoglycosides (gentamicin, tobramycin) are nephrotoxic; trough level monitoring and adequate hydration are essential."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q35"; versionId = "ptcb-v2"; text = "The generic name for Toprol XL is:"; options = ["Atenolol", "Carvedilol", "Metoprolol succinate", "Bisoprolol"]; correctOptionIndex = 2; explanation = "Metoprolol succinate (Toprol XL) is a selective beta-1 blocker in extended-release formulation for hypertension and heart failure."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q36"; versionId = "ptcb-v2"; text = "Which federal law established the scheduling of controlled substances in the United States?"; options = ["Pure Food and Drug Act (1906)", "Controlled Substances Act (1970)", "OBRA 90", "Drug Listing Act (1972)"]; correctOptionIndex = 1; explanation = "The Controlled Substances Act of 1970 created the current five-schedule system for regulating drugs with abuse potential."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q37"; versionId = "ptcb-v2"; text = "A root cause analysis (RCA) is performed to:"; options = ["Punish staff responsible for errors", "Identify underlying system failures that contribute to errors", "Satisfy insurance billing requirements", "Determine a patient's allergy history"]; correctOptionIndex = 1; explanation = "RCA is a systematic process used to identify the root system-level causes of adverse events to prevent future occurrences."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q38"; versionId = "ptcb-v2"; text = "What is the generic name for Singular?"; options = ["Fexofenadine", "Montelukast", "Cetirizine", "Budesonide"]; correctOptionIndex = 1; explanation = "Montelukast (Singulair) is a leukotriene receptor antagonist used for asthma prophylaxis and allergic rhinitis."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q39"; versionId = "ptcb-v2"; text = "What does HS mean as a prescription frequency?"; options = ["Every hour", "Every half-hour", "At bedtime", "Every shift"]; correctOptionIndex = 2; explanation = "HS (hora somni) means at bedtime."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q40"; versionId = "ptcb-v2"; text = "Which drug requires a baseline liver function test and periodic monitoring due to hepatotoxicity risk?"; options = ["Amoxicillin", "Atorvastatin", "Loratadine", "Metformin"]; correctOptionIndex = 1; explanation = "Statins including atorvastatin carry a risk of hepatotoxicity; liver function tests are recommended at baseline and periodically."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q41"; versionId = "ptcb-v2"; text = "How many fluid ounces are in 240 mL?"; options = ["4 fl oz", "8 fl oz", "16 fl oz", "12 fl oz"]; correctOptionIndex = 1; explanation = "240 mL / 30 mL per fl oz = 8 fl oz."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q42"; versionId = "ptcb-v2"; text = "Which of the following is a Schedule V medication that can sometimes be obtained without a prescription (per state law)?"; options = ["Codeine/acetaminophen (Tylenol #3)", "Cough syrup containing small amounts of codeine", "Alprazolam", "Oxycodone"]; correctOptionIndex = 1; explanation = "Some states allow dispensing of Schedule V cough preparations with codeine (e.g., Robitussin AC) without a prescription to adults with a pharmacist signature logbook entry."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q43"; versionId = "ptcb-v2"; text = "Which medication class requires monitoring of thyroid function tests (TFTs)?"; options = ["Statins", "Beta-blockers", "Amiodarone", "ACE inhibitors"]; correctOptionIndex = 2; explanation = "Amiodarone can cause thyroid dysfunction (both hypo- and hyperthyroidism) due to its high iodine content; TFTs must be monitored regularly."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q44"; versionId = "ptcb-v2"; text = "What is the brand name for lisinopril?"; options = ["Altace", "Accupril", "Zestril", "Univasc"]; correctOptionIndex = 2; explanation = "Lisinopril is marketed as Zestril and Prinivil. Altace = ramipril, Accupril = quinapril, Univasc = moexipril."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q45"; versionId = "ptcb-v2"; text = "A class recall issued by the FDA means:"; options = ["The product is dangerous but stays on market", "Withdrawal from the market with no risk of health harm", "Varies by recall class (I = most serious, III = least)", "Only applies to OTC products"]; correctOptionIndex = 2; explanation = "FDA recall classes: Class I = serious adverse health consequences/death, Class II = temporary adverse effects, Class III = unlikely to cause adverse health consequences."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q46"; versionId = "ptcb-v2"; text = "Which vitamin supplement is commonly recommended with isoniazid (INH) therapy?"; options = ["Vitamin C", "Vitamin B6 (Pyridoxine)", "Vitamin D", "Folate"]; correctOptionIndex = 1; explanation = "Isoniazid interferes with vitamin B6 (pyridoxine) metabolism, leading to peripheral neuropathy. Supplementation prevents this side effect."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q47"; versionId = "ptcb-v2"; text = "Which calculation gives the body surface area (BSA) dosing adjustment?"; options = ["Weight in kg divided by 70", "Square root of (height cm x weight kg / 3600)", "Weight x height / BMI", "Age in years x 2"]; correctOptionIndex = 1; explanation = "The Mosteller formula: BSA (m2) = square root of (height(cm) x weight(kg) / 3600). Used for chemotherapy dosing."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q48"; versionId = "ptcb-v2"; text = "Which of the following medications requires an international normalized ratio (INR) to monitor therapeutic effect?"; options = ["Aspirin", "Clopidogrel", "Warfarin", "Rivaroxaban"]; correctOptionIndex = 2; explanation = "Warfarin therapy is monitored using the INR (target range 2.0-3.0 for most indications)."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q49"; versionId = "ptcb-v2"; text = "Which of the following auxiliary labels should accompany doxycycline?"; options = ["Keep refrigerated", "Avoid sunlight", "Shake well", "Avoid dairy"]; correctOptionIndex = 1; explanation = "Doxycycline and other tetracyclines cause photosensitivity; patients should avoid prolonged sun/UV exposure."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q50"; versionId = "ptcb-v2"; text = "What is a formulary?"; options = ["A list of required pharmacy cleaning procedures", "An approved list of drugs covered by an insurance plan", "A database of all FDA-approved drugs", "A compounding manual"]; correctOptionIndex = 1; explanation = "A formulary is a list of preferred drugs covered by an insurance plan, used to guide prescribing and dispensing decisions."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q51"; versionId = "ptcb-v2"; text = "USP <795> covers standards for:"; options = ["Sterile compounding", "Non-sterile compounding", "Drug testing", "Packaging standards"]; correctOptionIndex = 1; explanation = "USP Chapter <795> sets standards for non-sterile compounding including BUD assignment, facilities, and quality controls."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q52"; versionId = "ptcb-v2"; text = "Which of the following is a Schedule IV controlled substance?"; options = ["Morphine", "Oxycodone", "Tramadol", "Heroin"]; correctOptionIndex = 2; explanation = "Tramadol is classified as a Schedule IV controlled substance due to its abuse and dependence potential."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q53"; versionId = "ptcb-v2"; text = "Insulin glargine (Lantus) should be stored at room temperature after opening for up to:"; options = ["7 days", "14 days", "28 days", "90 days"]; correctOptionIndex = 2; explanation = "After opening, insulin glargine vials and pens can be stored at room temperature (up to 30 degrees C) for up to 28 days."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q54"; versionId = "ptcb-v2"; text = "What is the primary purpose of a drug utilization review (DUR)?"; options = ["Reduce inventory costs", "Ensure appropriate prescribing and dispensing", "Track controlled substances for the DEA", "Determine insurance reimbursement"]; correctOptionIndex = 1; explanation = "DUR programs ensure medications are used appropriately, safely, and cost-effectively by screening for drug interactions, contraindications, and dosing issues."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q55"; versionId = "ptcb-v2"; text = "The brand name Lyrica corresponds to:"; options = ["Gabapentin", "Pregabalin", "Lamotrigine", "Levetiracetam"]; correctOptionIndex = 1; explanation = "Pregabalin (Lyrica) is used for neuropathic pain, fibromyalgia, and as an adjunct for epilepsy. Gabapentin (Neurontin) is a related but different drug."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q56"; versionId = "ptcb-v2"; text = "Convert 98.6 degrees Fahrenheit to Celsius:"; options = ["36 degrees C", "37 degrees C", "38 degrees C", "39 degrees C"]; correctOptionIndex = 1; explanation = "C = (F - 32) x 5/9 = (98.6 - 32) x 5/9 = 66.6 x 0.556 = 37 degrees C."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q57"; versionId = "ptcb-v2"; text = "Which of the following medications has a narrow therapeutic index requiring careful monitoring?"; options = ["Cetirizine", "Digoxin", "Omeprazole", "Loratadine"]; correctOptionIndex = 1; explanation = "Digoxin has a narrow therapeutic index; levels must be monitored carefully to avoid toxicity (symptoms: nausea, yellow vision, arrhythmias)."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q58"; versionId = "ptcb-v2"; text = "Which type of pharmacy compounding creates a new formulation for a specific patient's prescription?"; options = ["Anticipatory compounding", "Patient-specific compounding", "Commercial manufacturing", "Bulk compounding"]; correctOptionIndex = 1; explanation = "Patient-specific (or extemporaneous) compounding prepares a customized formulation based on an individual patient's prescription."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q59"; versionId = "ptcb-v2"; text = "The brand name Advair Diskus contains which combination?"; options = ["Albuterol and ipratropium", "Budesonide and formoterol", "Fluticasone and salmeterol", "Beclomethasone and albuterol"]; correctOptionIndex = 2; explanation = "Advair Diskus contains fluticasone (inhaled corticosteroid) and salmeterol (long-acting beta-2 agonist) for asthma and COPD maintenance."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q60"; versionId = "ptcb-v2"; text = "Which of the following is classified as a biologic medication?"; options = ["Metformin", "Adalimumab (Humira)", "Atorvastatin", "Lisinopril"]; correctOptionIndex = 1; explanation = "Adalimumab (Humira) is a biologic (monoclonal antibody) that targets TNF-alpha and is used for rheumatoid arthritis and other inflammatory conditions."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q61"; versionId = "ptcb-v2"; text = "Which of the following is the correct action when a HEPA filter in a laminar airflow workbench is damaged?"; options = ["Continue working and report at end of shift", "Stop all compounding and notify supervisor immediately", "Replace the filter yourself", "Use a backup workbench if available and do nothing else"]; correctOptionIndex = 1; explanation = "A damaged HEPA filter compromises ISO Class 5 air quality; all compounding must stop immediately and supervisor/pharmacy director must be notified."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q62"; versionId = "ptcb-v2"; text = "Which insulin type has the longest duration of action?"; options = ["Regular insulin", "NPH insulin", "Insulin lispro", "Insulin glargine"]; correctOptionIndex = 3; explanation = "Insulin glargine (Lantus) is a long-acting basal insulin with a relatively peakless profile lasting up to 24 hours."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q63"; versionId = "ptcb-v2"; text = "What does 'DAW' mean on a prescription?"; options = ["Dispense as written (brand only)", "Dispense all weekly", "Drug allowed with warning", "Double amount written"]; correctOptionIndex = 0; explanation = "DAW (Dispense as Written) instructs the pharmacist to dispense the brand-name product rather than substituting a generic."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q64"; versionId = "ptcb-v2"; text = "Rhabdomyolysis is a serious adverse effect associated with which drug class?"; options = ["ACE inhibitors", "Beta-blockers", "Statins", "Antibiotics"]; correctOptionIndex = 2; explanation = "Statins can cause rhabdomyolysis (muscle breakdown), releasing myoglobin that can lead to acute kidney injury. Risk increases with drug interactions (e.g., cyclosporine, gemfibrozil)."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q65"; versionId = "ptcb-v2"; text = "The pharmacist signs the bottom of a DEA Form 222. What does this signify?"; options = ["Patient has consent to receive Schedule II medications", "The form is valid and can be submitted to order Schedule II drugs", "The order has been received and verified", "The pharmacist is confirming insurance prior authorization"]; correctOptionIndex = 1; explanation = "DEA Form 222 must be signed and dated by the registrant (pharmacist/pharmacist-in-charge) to be a valid order for Schedule II controlled substances."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q66"; versionId = "ptcb-v2"; text = "Which of the following is a correct aseptic technique practice?"; options = ["Touching the rubber stopper without swabbing", "Working in the direct compounding area with hands between the HEPA filter and the product", "Performing compounding without wearing gloves", "Re-using syringes for multiple patients"]; correctOptionIndex = 1; explanation = "In a LAFW, the pharmacist/technician must work in the DCA (within 6 inches of HEPA filter outlet), maintaining first-air flow over critical sites."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q67"; versionId = "ptcb-v2"; text = "Which drug is the antidote for heparin overdose?"; options = ["Vitamin K", "Protamine sulfate", "Fresh frozen plasma", "Phytonadione"]; correctOptionIndex = 1; explanation = "Protamine sulfate reverses heparin anticoagulation by binding to and inactivating heparin."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q68"; versionId = "ptcb-v2"; text = "A prescription is written for warfarin 5 mg QHS. This means:"; options = ["5 mg four times daily", "5 mg at bedtime", "5 mg twice daily", "5 mg every 4 hours"]; correctOptionIndex = 1; explanation = "QHS (quaque hora somni) means every bedtime; warfarin is typically dosed once daily at bedtime."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q69"; versionId = "ptcb-v2"; text = "Which regulatory requirement states that new molecular entities must demonstrate safety and efficacy before approval?"; options = ["OBRA 90", "Kefauver-Harris Drug Amendments 1962", "Durham-Humphrey Amendment 1951", "Pure Food and Drug Act 1906"]; correctOptionIndex = 1; explanation = "The Kefauver-Harris Amendment (1962) strengthened drug approval by requiring manufacturers to prove both safety and efficacy before a new drug is approved."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q70"; versionId = "ptcb-v2"; text = "The generic name for Norco is:"; options = ["Oxycodone/acetaminophen", "Hydrocodone/acetaminophen", "Codeine/acetaminophen", "Morphine/ibuprofen"]; correctOptionIndex = 1; explanation = "Norco is a brand name for hydrocodone/acetaminophen 10/325 mg, a Schedule II combination opioid analgesic."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q71"; versionId = "ptcb-v2"; text = "Which of the following lab values should be monitored for patients taking metformin?"; options = ["INR", "Serum potassium", "Renal function (SCr/eGFR)", "Liver enzymes"]; correctOptionIndex = 2; explanation = "Metformin is contraindicated in severe renal impairment due to risk of lactic acidosis; serum creatinine and eGFR must be monitored."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q72"; versionId = "ptcb-v2"; text = "Which type of error is defined as giving the correct drug but via the wrong route?"; options = ["Wrong drug error", "Wrong route error", "Wrong time error", "Omission error"]; correctOptionIndex = 1; explanation = "A wrong route error occurs when a drug (otherwise correct) is administered via an unintended route (e.g., oral methotrexate given intrathecally)."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q73"; versionId = "ptcb-v2"; text = "The prefix 'ceph-' or 'cef-' in a drug name typically indicates:"; options = ["A penicillin antibiotic", "A cephalosporin antibiotic", "A macrolide antibiotic", "A fluoroquinolone antibiotic"]; correctOptionIndex = 1; explanation = "Cephalosporins include cephalexin, cefdinir, cefazolin, ceftriaxone — recognized by 'ceph-' or 'cef-' prefix."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q74"; versionId = "ptcb-v2"; text = "What is required when a Schedule II controlled substance must be destroyed at the pharmacy?"; options = ["Pour it down the sink", "Place in the regular trash", "Use DEA Form 41 or a DEA-authorized reverse distributor", "Return to manufacturer without paperwork"]; correctOptionIndex = 2; explanation = "Controlled substance destruction requires DEA Form 41 (on-site destruction with witness) or transfer to a DEA-registered reverse distributor."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q75"; versionId = "ptcb-v2"; text = "A physician orders cefazolin 1 g IV q8h. How many doses are in a 3-day supply?"; options = ["6 doses", "9 doses", "12 doses", "24 doses"]; correctOptionIndex = 1; explanation = "q8h = 3 doses/day x 3 days = 9 doses."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q76"; versionId = "ptcb-v2"; text = "Which of the following describes a medication's half-life?"; options = ["Time for 100% of drug to be eliminated", "Time for plasma concentration to decrease by 50%", "Time for drug to reach steady state", "Time from administration to peak effect"]; correctOptionIndex = 1; explanation = "Half-life (t1/2) is the time for the plasma drug concentration to decrease by 50%. Approximately 5 half-lives are needed to reach steady state or near-complete elimination."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q77"; versionId = "ptcb-v2"; text = "Which of the following is a direct oral anticoagulant (DOAC)?"; options = ["Warfarin", "Heparin", "Enoxaparin", "Rivaroxaban (Xarelto)"]; correctOptionIndex = 3; explanation = "Rivaroxaban (Xarelto) is a direct factor Xa inhibitor, one of the newer DOACs used for atrial fibrillation and DVT/PE treatment."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q78"; versionId = "ptcb-v2"; text = "Prescription records for Schedule II substances must be maintained for a minimum of how many years under federal law?"; options = ["1 year", "2 years", "5 years", "10 years"]; correctOptionIndex = 1; explanation = "Federal DEA regulations require that Schedule II prescription records be maintained for a minimum of 2 years (states may require longer)."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q79"; versionId = "ptcb-v2"; text = "Which of the following is an indication for calcium gluconate administration?"; options = ["Hyponatremia", "Hyperkalemia causing cardiac toxicity", "Hypomagnesemia", "Metabolic alkalosis"]; correctOptionIndex = 1; explanation = "Calcium gluconate is given IV to stabilize cardiac membranes in hyperkalemia-induced cardiac toxicity, providing immediate but short-term cardiac protection."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q80"; versionId = "ptcb-v2"; text = "Which term describes a drug error where a dose is not administered as prescribed?"; options = ["Commission error", "Omission error", "Wrong time error", "Deteriorated drug error"]; correctOptionIndex = 1; explanation = "An omission error occurs when a scheduled dose is not given to the patient."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q81"; versionId = "ptcb-v2"; text = "What is the generic name for Ambien CR?"; options = ["Zolpidem extended-release", "Eszopiclone", "Ramelteon", "Zaleplon"]; correctOptionIndex = 0; explanation = "Ambien CR is the controlled-release formulation of zolpidem tartrate, used for sleep onset and sleep maintenance insomnia."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q82"; versionId = "ptcb-v2"; text = "Under the Durham-Humphrey Amendment (1951), which drug category requires a prescription?"; options = ["Vitamins", "OTC analgesics", "Legend drugs (Rx-only)", "Dietary supplements"]; correctOptionIndex = 2; explanation = "The Durham-Humphrey Amendment distinguished prescription (legend) drugs requiring a prescriber's order from OTC products available without a prescription."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q83"; versionId = "ptcb-v2"; text = "A beyond-use date (BUD) differs from an expiration date because:"; options = ["BUD applies to manufacturer products only", "BUD is assigned after the product is opened or compounded", "BUD is always longer than the expiration date", "BUD is set by the DEA"]; correctOptionIndex = 1; explanation = "BUD is assigned based on USP standards after a product is opened, diluted, or compounded. The expiration date is set by the manufacturer for the unopened product."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q84"; versionId = "ptcb-v2"; text = "Which of the following conversions is correct?"; options = ["1 lb = 500 g", "1 kg = 100 lb", "1 oz = 30 g", "1 grain = 100 mg"]; correctOptionIndex = 2; explanation = "1 avoirdupois ounce = approximately 30 g. 1 grain = 64.8 mg, 1 kg = 2.2 lb."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q85"; versionId = "ptcb-v2"; text = "Which of the following is a common side effect of opioids?"; options = ["Diarrhea", "Hypertension", "Constipation", "Hyperglycemia"]; correctOptionIndex = 2; explanation = "Constipation is the most consistent and persistent side effect of opioid therapy due to decreased gut motility; it does not resolve with tolerance."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q86"; versionId = "ptcb-v2"; text = "A pharmacy receives a prescription for testosterone cypionate 200 mg/mL, 10 mL vial. How many total mg are in the vial?"; options = ["200 mg", "500 mg", "1000 mg", "2000 mg"]; correctOptionIndex = 3; explanation = "200 mg/mL x 10 mL = 2000 mg total in the vial."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q87"; versionId = "ptcb-v2"; text = "Which of the following is a correct requirement for a pharmacist to dispense a Schedule III-V drug?"; options = ["Written original prescription only", "Verbal or written prescription; may be transferred once (Schedule III-V)", "DEA Form 222 required", "Schedule III-V cannot be called in"]; correctOptionIndex = 1; explanation = "Schedule III-V drugs may be dispensed based on written or oral prescriptions and may be transferred (generally once) between pharmacies."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q88"; versionId = "ptcb-v2"; text = "Which of the following is the standard concentration of heparin in a flush syringe used in most hospitals?"; options = ["1000 units/mL", "5000 units/mL", "10 units/mL or 100 units/mL", "500 units/mL"]; correctOptionIndex = 2; explanation = "Heparin flush syringes typically contain 10 units/mL or 100 units/mL. High-concentration heparin (1000-5000 units/mL) is a high-alert medication associated with fatal errors."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q89"; versionId = "ptcb-v2"; text = "Which drug interaction results in a significantly increased risk of bleeding?"; options = ["Warfarin + metformin", "Warfarin + vitamin E supplementation", "Clopidogrel + omeprazole", "Aspirin + amoxicillin"]; correctOptionIndex = 1; explanation = "High-dose vitamin E inhibits vitamin K-dependent clotting factors and can potentiate warfarin's anticoagulant effect, increasing bleeding risk."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v2-q90"; versionId = "ptcb-v2"; text = "Which process does a pharmacy implement to ensure proper handling of returned or expired medications?"; options = ["DUR", "Reverse distribution", "Formulary management", "Therapeutic substitution"]; correctOptionIndex = 1; explanation = "Reverse distribution is the process by which expired or returned medications are sent back through a DEA-registered reverse distributor for proper disposal or credit."; knowledgeDomain = #FederalRequirements; isScored = true });

    // Practice Test 3
    addQuestionIfMissing(questions, { id = "ptcb-v3-q1"; versionId = "ptcb-v3"; text = "A 500 mL bag of D5W is infused over 4 hours via a 15 gtt/mL set. What is the drip rate in gtt/min?"; options = ["21 gtt/min", "31 gtt/min", "42 gtt/min", "63 gtt/min"]; correctOptionIndex = 1; explanation = "Drip rate = (500 mL x 15 gtt/mL) / (4 h x 60 min/h) = 7500 / 240 = approx. 31 gtt/min."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q2"; versionId = "ptcb-v3"; text = "Which of the following medications has a REMS program due to risk of teratogenicity?"; options = ["Metformin", "Isotretinoin (Accutane)", "Lisinopril", "Omeprazole"]; correctOptionIndex = 1; explanation = "Isotretinoin requires the iPLEDGE REMS program to prevent fetal exposure due to severe birth defect risk."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q3"; versionId = "ptcb-v3"; text = "Which of the following is a proton pump inhibitor?"; options = ["Ranitidine", "Famotidine", "Omeprazole", "Metoclopramide"]; correctOptionIndex = 2; explanation = "Omeprazole (Prilosec) is a proton pump inhibitor. Ranitidine and famotidine are H2 blockers; metoclopramide is a prokinetic."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q4"; versionId = "ptcb-v3"; text = "Which of the five rights of medication administration refers to confirming the patient identity?"; options = ["Right drug", "Right dose", "Right patient", "Right route"]; correctOptionIndex = 2; explanation = "The Right Patient is one of the five rights of medication administration, typically verified by two identifiers (name and date of birth)."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q5"; versionId = "ptcb-v3"; text = "What is the generic name for Coumadin?"; options = ["Heparin", "Enoxaparin", "Warfarin", "Dabigatran"]; correctOptionIndex = 2; explanation = "Warfarin (Coumadin) is a vitamin K antagonist anticoagulant requiring regular INR monitoring."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q6"; versionId = "ptcb-v3"; text = "A pharmacy technician notices two patients received each other's prescriptions. What should be done first?"; options = ["Document the error and continue", "Alert the pharmacist immediately", "Contact both patients directly", "Correct the labels without notifying anyone"]; correctOptionIndex = 1; explanation = "Patient safety requires immediate escalation to the pharmacist who can assess harm and implement corrective action."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q7"; versionId = "ptcb-v3"; text = "Which DEA schedule includes drugs with no accepted medical use in the United States?"; options = ["Schedule I", "Schedule II", "Schedule III", "Schedule IV"]; correctOptionIndex = 0; explanation = "Schedule I drugs (e.g., heroin, LSD) have no accepted medical use and high abuse potential."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q8"; versionId = "ptcb-v3"; text = "Amoxicillin 250 mg/5 mL suspension. How many mL are needed for a 500 mg dose?"; options = ["5 mL", "10 mL", "15 mL", "20 mL"]; correctOptionIndex = 1; explanation = "500 mg divided by (250 mg/5 mL) = 10 mL."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q9"; versionId = "ptcb-v3"; text = "Which of the following is an example of a high-alert medication?"; options = ["Acetaminophen tablets", "Multivitamins", "Concentrated potassium chloride injection", "Artificial tears"]; correctOptionIndex = 2; explanation = "Concentrated KCl injection is a high-alert medication because improper administration can cause fatal cardiac arrhythmias."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q10"; versionId = "ptcb-v3"; text = "Which drug class ends with the suffix -mab?"; options = ["Kinase inhibitors", "Monoclonal antibodies", "Protease inhibitors", "Beta-lactam antibiotics"]; correctOptionIndex = 1; explanation = "The suffix -mab denotes monoclonal antibodies (e.g., adalimumab, trastuzumab, bevacizumab)."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q11"; versionId = "ptcb-v3"; text = "HIPAA regulations primarily protect:"; options = ["Drug pricing information", "Patient health information", "Pharmacy inventory data", "Insurance billing rates"]; correctOptionIndex = 1; explanation = "HIPAA (Health Insurance Portability and Accountability Act) protects individually identifiable patient health information (PHI)."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q12"; versionId = "ptcb-v3"; text = "A Schedule II prescription for Adderall cannot be:"; options = ["Filled with a written prescription", "Filled with an e-prescribing order", "Transferred to another pharmacy", "Dispensed with a 30-day supply"]; correctOptionIndex = 2; explanation = "Schedule II prescriptions cannot be transferred between pharmacies. The patient must obtain a new prescription."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q13"; versionId = "ptcb-v3"; text = "Which drug class is used to reduce gastric acid secretion by blocking H2 receptors?"; options = ["Proton pump inhibitors", "Antacids", "H2 blockers", "Prokinetics"]; correctOptionIndex = 2; explanation = "H2 blockers (famotidine, cimetidine, nizatidine) reduce gastric acid production by blocking histamine H2 receptors on parietal cells."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q14"; versionId = "ptcb-v3"; text = "How many mL are in 1 teaspoon?"; options = ["2.5 mL", "5 mL", "10 mL", "15 mL"]; correctOptionIndex = 1; explanation = "1 teaspoon = 5 mL; 1 tablespoon = 15 mL; 1 fl oz = 30 mL."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q15"; versionId = "ptcb-v3"; text = "Which of the following is a correct statement about Schedule II prescriptions?"; options = ["They may be refilled up to 5 times in 6 months", "They may be called in verbally in any non-emergency situation", "They require a new written or electronic prescription for each fill", "They can be partially filled only in a nursing home"]; correctOptionIndex = 2; explanation = "Schedule II controlled substances require a new, valid written or electronic prescription for each fill. No refills are allowed."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q16"; versionId = "ptcb-v3"; text = "Which of the following is a long-acting beta-2 agonist (LABA) used in asthma maintenance?"; options = ["Albuterol", "Levalbuterol", "Salmeterol", "Ipratropium"]; correctOptionIndex = 2; explanation = "Salmeterol (Serevent) is a long-acting beta-2 agonist used for maintenance therapy; it should never be used alone without an inhaled corticosteroid in asthma."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q17"; versionId = "ptcb-v3"; text = "Which of the following requires that pharmacies offer patient counseling to Medicaid patients before dispensing?"; options = ["HIPAA", "OBRA 90", "Controlled Substances Act", "Kefauver-Harris Amendment"]; correctOptionIndex = 1; explanation = "OBRA 90 mandates that pharmacists offer to counsel Medicaid patients on new prescriptions and perform drug utilization reviews."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q18"; versionId = "ptcb-v3"; text = "A pediatric patient weighs 18 kg. If the dose is 10 mg/kg/day in two divided doses, what is each dose?"; options = ["90 mg", "180 mg", "360 mg", "45 mg"]; correctOptionIndex = 0; explanation = "10 mg/kg/day x 18 kg = 180 mg/day / 2 doses = 90 mg per dose."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q19"; versionId = "ptcb-v3"; text = "Which is an example of an error-prone abbreviation that should be written out in full?"; options = ["mg", "mL", "QD (should be 'daily')", "PO"]; correctOptionIndex = 2; explanation = "QD is on the ISMP error-prone abbreviation list because it is easily confused with QID (4 times daily). 'Daily' should be written out."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q20"; versionId = "ptcb-v3"; text = "What does the NDC number on a drug product identify?"; options = ["Drug schedule", "Manufacturer, product, and package size", "Insurance formulary tier", "Patient's prescription number"]; correctOptionIndex = 1; explanation = "The National Drug Code (NDC) is a unique 10- or 11-digit number identifying the manufacturer/labeler, the specific product, and the package size."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q21"; versionId = "ptcb-v3"; text = "Which drug is a first-line treatment for type 2 diabetes per most guidelines?"; options = ["Insulin glargine", "Metformin", "Glipizide", "Sitagliptin"]; correctOptionIndex = 1; explanation = "Metformin is the first-line pharmacologic agent for type 2 diabetes due to its efficacy, safety profile, low cost, and weight-neutral to weight-reducing effects."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q22"; versionId = "ptcb-v3"; text = "A 70 kg patient requires vancomycin at 15 mg/kg every 12 hours. What is each dose?"; options = ["750 mg", "1050 mg", "1500 mg", "2100 mg"]; correctOptionIndex = 1; explanation = "15 mg/kg x 70 kg = 1050 mg per dose."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q23"; versionId = "ptcb-v3"; text = "Which of the following medications requires a PPE/safety protocol when handled due to hazardous drug classification?"; options = ["Amoxicillin", "Methotrexate", "Acetaminophen", "Atorvastatin"]; correctOptionIndex = 1; explanation = "Methotrexate is classified as a hazardous drug by NIOSH; it requires double gloves, protective gown, and closed-system transfer devices when compounding."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q24"; versionId = "ptcb-v3"; text = "What is the generic name for Diflucan?"; options = ["Terbinafine", "Itraconazole", "Fluconazole", "Clotrimazole"]; correctOptionIndex = 2; explanation = "Fluconazole (Diflucan) is a triazole antifungal used for Candida infections, thrush, and cryptococcal meningitis."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q25"; versionId = "ptcb-v3"; text = "What Roman numeral quantity means 'one and a half' in pharmacy notation?"; options = ["Iss", "II", "Iii", "Ivss"]; correctOptionIndex = 0; explanation = "'Iss' represents 1.5 (one plus ss = one-half) in apothecary/Roman numeral pharmacy notation."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q26"; versionId = "ptcb-v3"; text = "Which anticoagulant can be reversed with protamine sulfate?"; options = ["Warfarin", "Rivaroxaban", "Unfractionated heparin", "Dabigatran"]; correctOptionIndex = 2; explanation = "Protamine sulfate reverses unfractionated heparin anticoagulation. Warfarin is reversed by vitamin K/FFP; dabigatran by idarucizumab; rivaroxaban by andexanet alfa."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q27"; versionId = "ptcb-v3"; text = "Which medication category must be stored separately from other drugs and requires dedicated storage per The Joint Commission?"; options = ["Antibiotics", "High-alert medications", "OTC drugs", "Vitamins"]; correctOptionIndex = 1; explanation = "TJC and ISMP require high-alert medications (concentrated electrolytes, anticoagulants, insulin, opioids) to be stored separately with additional safety checks."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q28"; versionId = "ptcb-v3"; text = "A prescription reads: 'Lisinopril 10 mg, i tab QD, Disp #90, Refills 3.' How many total tablets may be dispensed?"; options = ["90 tablets", "270 tablets", "360 tablets", "450 tablets"]; correctOptionIndex = 2; explanation = "Initial fill 90 + 3 refills x 90 = 90 + 270 = 360 tablets total."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q29"; versionId = "ptcb-v3"; text = "Which of the following is an inhaled corticosteroid (ICS) used for asthma maintenance?"; options = ["Albuterol", "Montelukast", "Fluticasone", "Theophylline"]; correctOptionIndex = 2; explanation = "Fluticasone (Flovent) is an inhaled corticosteroid used as maintenance therapy to reduce airway inflammation in asthma."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q30"; versionId = "ptcb-v3"; text = "Which of the following is true about Schedule V substances compared to Schedule II?"; options = ["Schedule V has higher abuse potential", "Schedule V has more restrictions on refills", "Schedule V drugs have lower abuse potential and fewer dispensing restrictions", "Schedule V includes heroin and LSD"]; correctOptionIndex = 2; explanation = "Schedule V drugs (e.g., pregabalin, cough preps with small amounts of codeine) have the lowest abuse potential and fewest restrictions among scheduled substances."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q31"; versionId = "ptcb-v3"; text = "What is the generic name for Zocor?"; options = ["Atorvastatin", "Pravastatin", "Simvastatin", "Lovastatin"]; correctOptionIndex = 2; explanation = "Simvastatin (Zocor) is an HMG-CoA reductase inhibitor used to lower LDL cholesterol and triglycerides."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q32"; versionId = "ptcb-v3"; text = "Calculate the infusion rate: 250 mL over 2 hours using a 60 gtt/mL microdrip set. Drip rate in gtt/min?"; options = ["100 gtt/min", "125 gtt/min", "250 gtt/min", "30 gtt/min"]; correctOptionIndex = 1; explanation = "(250 mL x 60 gtt/mL) / (2 h x 60 min/h) = 15000 / 120 = 125 gtt/min."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q33"; versionId = "ptcb-v3"; text = "Which class of medication is budesonide/formoterol (Symbicort)?"; options = ["Short-acting beta agonist / anticholinergic combination", "Inhaled corticosteroid / long-acting beta agonist combination", "Leukotriene modifier / antihistamine combination", "Oral corticosteroid / theophylline combination"]; correctOptionIndex = 1; explanation = "Symbicort contains budesonide (ICS) and formoterol (LABA), used for asthma and COPD maintenance."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q34"; versionId = "ptcb-v3"; text = "The 'look-alike, sound-alike' drug error prevention strategy includes:"; options = ["Storing LASA drugs next to each other for convenience", "Using tall man lettering and physical separation of similar-looking drugs", "Removing all labels from drug bins", "Ordering LASA drugs from the same manufacturer"]; correctOptionIndex = 1; explanation = "Tall man lettering and physical separation of LASA drugs are recommended strategies to prevent dispensing errors."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q35"; versionId = "ptcb-v3"; text = "Which medication is an alpha-1 blocker used to treat benign prostatic hyperplasia (BPH)?"; options = ["Finasteride", "Tamsulosin", "Dutasteride", "Sildenafil"]; correctOptionIndex = 1; explanation = "Tamsulosin (Flomax) is an alpha-1 adrenergic blocker that relaxes smooth muscle in the prostate and bladder neck to improve urinary flow in BPH."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q36"; versionId = "ptcb-v3"; text = "How are Schedule III-V prescriptions different from Schedule II with regard to refills?"; options = ["Schedule III-V cannot be refilled", "Schedule III-V may be refilled up to 5 times within 6 months", "Schedule III-V may be refilled indefinitely", "Schedule III-V require DEA Form 222 for refills"]; correctOptionIndex = 1; explanation = "Schedule III-V prescriptions may be refilled up to 5 times within 6 months of the original issue date. Schedule II prescriptions cannot be refilled."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q37"; versionId = "ptcb-v3"; text = "Which of the following is a correct statement about insulin mixtures?"; options = ["Cloudy insulin is always expired", "NPH must be drawn up before regular insulin in a mixed dose", "Regular insulin should be drawn up first in a mixed-dose syringe", "All insulin types can be mixed freely"]; correctOptionIndex = 2; explanation = "When mixing regular and NPH insulin, regular (clear) is drawn up first to avoid contaminating the regular insulin vial with NPH (cloudy)."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q38"; versionId = "ptcb-v3"; text = "A patient taking lithium should be advised to:"; options = ["Increase sodium intake", "Maintain consistent sodium and fluid intake", "Avoid all dairy", "Take with grapefruit juice"]; correctOptionIndex = 1; explanation = "Lithium levels are sensitive to sodium and fluid balance. Low sodium intake leads to lithium retention and toxicity; consistent intake is critical."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q39"; versionId = "ptcb-v3"; text = "What is the generic name for Lantus?"; options = ["Insulin lispro", "Insulin aspart", "Insulin glargine", "Insulin detemir"]; correctOptionIndex = 2; explanation = "Insulin glargine (Lantus) is a long-acting analog insulin with a 24-hour flat action profile, dosed once daily."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q40"; versionId = "ptcb-v3"; text = "Which abbreviation should be written as 'units' to prevent medication errors?"; options = ["mg", "mL", "U", "mcg"]; correctOptionIndex = 2; explanation = "'U' for units is on the ISMP do-not-use list because it can be mistaken for '0' (zero) or '4'. 'Units' should always be written out."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q41"; versionId = "ptcb-v3"; text = "A prescription for Percocet is written. Percocet contains:"; options = ["Hydrocodone/acetaminophen", "Oxycodone/acetaminophen", "Codeine/acetaminophen", "Morphine/ibuprofen"]; correctOptionIndex = 1; explanation = "Percocet contains oxycodone and acetaminophen. It is a Schedule II combination opioid analgesic."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q42"; versionId = "ptcb-v3"; text = "Which is the maximum pseudoephedrine purchase under CMEA (Combat Methamphetamine Epidemic Act) per 30 days?"; options = ["3.6 g daily, 7.5 g monthly", "9 g per 30 days", "15 g per 30 days", "1.8 g daily, 3.6 g per purchase"]; correctOptionIndex = 1; explanation = "CMEA limits pseudoephedrine purchases to 3.6 g per day and 9 g per 30-day period per person."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q43"; versionId = "ptcb-v3"; text = "What is the purpose of bar-code medication administration (BCMA) technology?"; options = ["Speed up pill counting", "Verify the 5 rights at the bedside before medication administration", "Track inventory levels", "Process insurance claims"]; correctOptionIndex = 1; explanation = "BCMA systems scan the patient's wristband and the medication barcode at the point of care to verify the right patient, drug, dose, route, and time."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q44"; versionId = "ptcb-v3"; text = "The generic name for Neurontin is:"; options = ["Pregabalin", "Gabapentin", "Lamotrigine", "Valproate"]; correctOptionIndex = 1; explanation = "Gabapentin (Neurontin) is used for neuropathic pain, epilepsy, and restless legs syndrome. Pregabalin (Lyrica) is a related but distinct drug."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q45"; versionId = "ptcb-v3"; text = "Prepare a 1:1000 epinephrine solution. How many mg are in 1 mL?"; options = ["0.1 mg/mL", "0.5 mg/mL", "1 mg/mL", "10 mg/mL"]; correctOptionIndex = 2; explanation = "1:1000 = 1 g per 1000 mL = 1 mg per mL. 1:10,000 = 0.1 mg/mL."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q46"; versionId = "ptcb-v3"; text = "A pharmacist may not substitute a generic unless:"; options = ["The prescriber has authorized substitution by not writing 'DAW'", "The patient requests brand only", "The generic costs more than the brand", "The drug is a controlled substance"]; correctOptionIndex = 0; explanation = "Generic substitution is permitted when the prescriber has not indicated 'Dispense as Written' (DAW) or 'brand only'. Patient consent and state laws also apply."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q47"; versionId = "ptcb-v3"; text = "Which insulin analogue is considered ultra-rapid acting?"; options = ["NPH", "Insulin glargine", "Insulin aspart", "Insulin degludec"]; correctOptionIndex = 2; explanation = "Insulin aspart (NovoLog) is a rapid-acting analog with onset within 15 minutes. Ultra-rapid formulations like Fiasp begin working even faster."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q48"; versionId = "ptcb-v3"; text = "OSHA's Hazard Communication Standard (HazCom) requires pharmacies to maintain:"; options = ["Patient prescription records", "Safety Data Sheets (SDS) for hazardous chemicals", "DEA drug inventory logs", "Pharmacy board registration documents"]; correctOptionIndex = 1; explanation = "OSHA's HazCom standard requires employers to keep Safety Data Sheets (formerly MSDS) accessible to employees for all hazardous chemicals in the workplace."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q49"; versionId = "ptcb-v3"; text = "The brand name Cymbalta corresponds to:"; options = ["Sertraline", "Fluoxetine", "Duloxetine", "Venlafaxine"]; correctOptionIndex = 2; explanation = "Duloxetine (Cymbalta) is a serotonin-norepinephrine reuptake inhibitor (SNRI) used for depression, anxiety, and neuropathic pain."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q50"; versionId = "ptcb-v3"; text = "How many mcg are in 1 mg?"; options = ["10 mcg", "100 mcg", "1000 mcg", "0.1 mcg"]; correctOptionIndex = 2; explanation = "1 mg = 1000 mcg (micrograms). This conversion is critical for drugs dosed in mcg (e.g., levothyroxine, fentanyl patches)."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q51"; versionId = "ptcb-v3"; text = "Which of the following is a non-steroidal anti-inflammatory drug (NSAID)?"; options = ["Prednisone", "Methylprednisolone", "Celecoxib", "Hydrocortisone"]; correctOptionIndex = 2; explanation = "Celecoxib (Celebrex) is a COX-2 selective NSAID. Prednisone, methylprednisolone, and hydrocortisone are corticosteroids (not NSAIDs)."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q52"; versionId = "ptcb-v3"; text = "Which process ensures proper medication security, tracking, and documentation in the pharmacy?"; options = ["Drug utilization review", "Perpetual inventory", "Formulary management", "Therapeutic substitution"]; correctOptionIndex = 1; explanation = "A perpetual inventory system continuously tracks controlled substance quantities dispensed and on hand, required by the DEA for Schedule II drugs."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q53"; versionId = "ptcb-v3"; text = "Which medication should be avoided in patients with a sulfa allergy?"; options = ["Penicillin", "Furosemide", "Metformin", "Cephalexin"]; correctOptionIndex = 1; explanation = "Furosemide contains a sulfonamide moiety and should be used cautiously in patients with sulfa allergy, though cross-reactivity risk is considered low."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q54"; versionId = "ptcb-v3"; text = "What temperature is considered 'controlled room temperature' per USP?"; options = ["2 to 8 degrees C", "8 to 15 degrees C", "20 to 25 degrees C", "30 to 40 degrees C"]; correctOptionIndex = 2; explanation = "USP defines controlled room temperature (CRT) as 20 to 25 degrees C, with excursions allowed between 15 and 30 degrees C."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q55"; versionId = "ptcb-v3"; text = "The brand name Effexor XR corresponds to:"; options = ["Desvenlafaxine", "Venlafaxine", "Duloxetine", "Bupropion"]; correctOptionIndex = 1; explanation = "Venlafaxine (Effexor XR) is an SNRI antidepressant used for depression, generalized anxiety disorder, and panic disorder."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q56"; versionId = "ptcb-v3"; text = "Which of the following is the correct amount to dispense for 'Amoxicillin 400 mg/5 mL suspension, i tsp TID x 10 days'?"; options = ["50 mL", "100 mL", "150 mL", "200 mL"]; correctOptionIndex = 2; explanation = "1 tsp = 5 mL; TID x 10 days = 30 doses; 30 x 5 mL = 150 mL."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q57"; versionId = "ptcb-v3"; text = "Which of the following drugs is indicated for the treatment of MRSA infections?"; options = ["Amoxicillin", "Cephalexin", "Vancomycin", "Azithromycin"]; correctOptionIndex = 2; explanation = "Vancomycin is the drug of choice for serious MRSA (methicillin-resistant Staphylococcus aureus) infections including bacteremia and pneumonia."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q58"; versionId = "ptcb-v3"; text = "Pharmacy technicians are NOT permitted to:"; options = ["Enter prescription data into the computer", "Count and label medications", "Perform the final verification check on a prescription", "Prepare IV admixtures under pharmacist supervision"]; correctOptionIndex = 2; explanation = "The final verification (pharmacist check) is the exclusive responsibility of the licensed pharmacist. Technicians may prepare but not verify the final product."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q59"; versionId = "ptcb-v3"; text = "Which drug class is most likely to cause a photosensitivity reaction?"; options = ["ACE inhibitors", "Beta-blockers", "Tetracyclines", "Calcium channel blockers"]; correctOptionIndex = 2; explanation = "Tetracyclines (doxycycline, tetracycline) and fluoroquinolones are commonly associated with photosensitivity; patients must avoid sun/UV exposure."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q60"; versionId = "ptcb-v3"; text = "Which of the following is an advantage of an automated dispensing cabinet (ADC) in a hospital?"; options = ["Eliminates the need for pharmacist verification", "Provides immediate access to medications while maintaining controlled dispensing records", "Removes the need for drug storage guidelines", "Allows patients to self-administer medications"]; correctOptionIndex = 1; explanation = "ADCs (e.g., Pyxis, Omnicell) improve medication security, access, and record-keeping while requiring staff authentication and maintaining dispensing logs."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q61"; versionId = "ptcb-v3"; text = "What is the days supply for 'Ventolin HFA 90 mcg, 2 puffs QID prn, 1 inhaler (200 actuations)'?"; options = ["12 days", "25 days", "50 days", "100 days"]; correctOptionIndex = 1; explanation = "2 puffs x 4 times/day = 8 puffs/day; 200 actuations / 8 = 25 days supply."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q62"; versionId = "ptcb-v3"; text = "Which of the following is a correct principle of first-in, first-out (FIFO) inventory management?"; options = ["Newest stock is placed in front and used first", "Oldest stock is placed in front and used first", "All stock expires on the same date", "Stock is rotated monthly regardless of date"]; correctOptionIndex = 1; explanation = "FIFO means the oldest stock (earliest expiration) is placed at the front and used before newer stock to minimize waste and expired product."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q63"; versionId = "ptcb-v3"; text = "Which of the following describes a pharmacokinetic drug-drug interaction?"; options = ["Two drugs that both cause sedation are combined", "A drug changes the absorption, distribution, metabolism, or excretion of another", "Two drugs that have opposing therapeutic effects cancel each other out", "Two drugs that treat the same condition are used together"]; correctOptionIndex = 1; explanation = "Pharmacokinetic interactions involve changes in ADME of one drug by another (e.g., CYP450 induction/inhibition). Pharmacodynamic interactions involve additive/antagonistic effects."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q64"; versionId = "ptcb-v3"; text = "Which law requires that all OTC product labels include active ingredients, uses, and warnings?"; options = ["Durham-Humphrey Amendment", "OTC Monograph System / FFDCA regulations", "OBRA 90", "HIPAA"]; correctOptionIndex = 1; explanation = "FDA's OTC monograph system (under the FFDCA) requires standardized labeling for OTC products, including drug facts, active ingredients, and warnings."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q65"; versionId = "ptcb-v3"; text = "The generic name for Ultram is:"; options = ["Oxycodone", "Hydrocodone", "Tramadol", "Codeine"]; correctOptionIndex = 2; explanation = "Tramadol (Ultram) is a Schedule IV centrally acting opioid analgesic also inhibiting serotonin and norepinephrine reuptake."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q66"; versionId = "ptcb-v3"; text = "Which IV compatibility resource should be used to verify if two drugs can be mixed in the same IV bag?"; options = ["Orange Book", "Trissel's Handbook of Injectable Drugs", "Red Book", "PDR"]; correctOptionIndex = 1; explanation = "Trissel's Handbook of Injectable Drugs is the standard reference for IV drug compatibility and stability information."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q67"; versionId = "ptcb-v3"; text = "Levothyroxine 100 mcg is equivalent to how many mg?"; options = ["0.1 mg", "1 mg", "10 mg", "0.01 mg"]; correctOptionIndex = 0; explanation = "100 mcg / 1000 mcg per mg = 0.1 mg. Levothyroxine is typically expressed in mcg."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q68"; versionId = "ptcb-v3"; text = "Which of the following is a short-acting insulin with onset within 30 minutes?"; options = ["Insulin glargine", "Insulin NPH", "Regular insulin (Humulin R)", "Insulin detemir"]; correctOptionIndex = 2; explanation = "Regular insulin (Humulin R, Novolin R) has onset within 30-60 minutes, peak 2-4 hours, duration 5-8 hours."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q69"; versionId = "ptcb-v3"; text = "Which of the following must be present on a valid prescription to be legally dispensed?"; options = ["Patient date of birth", "Insurance group number", "Prescriber's signature", "Prescriber's license number"]; correctOptionIndex = 2; explanation = "A prescriber's signature (handwritten or electronic) is a federal requirement for a valid prescription. Date of birth may be required by state law."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q70"; versionId = "ptcb-v3"; text = "Which form of quality control involves checking a compounded product after it is made?"; options = ["Prospective DUR", "Retrospective quality review", "Final product verification", "Root cause analysis"]; correctOptionIndex = 2; explanation = "Final product verification (pharmacist check) is a retrospective quality control step performed after compounding to verify accuracy before dispensing."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q71"; versionId = "ptcb-v3"; text = "What is the brand name for metoprolol tartrate (immediate-release)?"; options = ["Toprol XL", "Lopressor", "Coreg", "Tenormin"]; correctOptionIndex = 1; explanation = "Metoprolol tartrate is marketed as Lopressor (immediate-release). Toprol XL = metoprolol succinate (extended-release)."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q72"; versionId = "ptcb-v3"; text = "Fluoxetine (Prozac) belongs to which drug class?"; options = ["SNRI", "TCA", "SSRI", "MAOI"]; correctOptionIndex = 2; explanation = "Fluoxetine (Prozac) is a selective serotonin reuptake inhibitor (SSRI) used for depression, OCD, and bulimia."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q73"; versionId = "ptcb-v3"; text = "A prescription for triamcinolone 0.1% cream, apply TID to affected area, 30 g tube. Days supply if 1 g per application:"; options = ["5 days", "10 days", "30 days", "90 days"]; correctOptionIndex = 1; explanation = "30 g / 1 g per application / 3 applications per day = 10 days supply."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q74"; versionId = "ptcb-v3"; text = "Which of the following is true about compounding a preparation that is commercially available?"; options = ["Allowed without restriction", "Generally not permitted unless there is a valid patient-specific clinical reason", "Required when generic versions exist", "Always requires FDA approval"]; correctOptionIndex = 1; explanation = "Compounding a preparation that is commercially available is generally not permitted unless there is a specific clinical need for the patient (e.g., different route or concentration)."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q75"; versionId = "ptcb-v3"; text = "Which drug class is associated with causing torsades de pointes arrhythmia?"; options = ["Beta-blockers", "ACE inhibitors", "QT-prolonging drugs (antipsychotics, certain antibiotics)", "Proton pump inhibitors"]; correctOptionIndex = 2; explanation = "Torsades de pointes is associated with QT-prolonging drugs including certain antipsychotics (haloperidol), antibiotics (azithromycin), and antiarrhythmics (amiodarone, sotalol)."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q76"; versionId = "ptcb-v3"; text = "Which acronym represents the organization responsible for setting safe medication use guidelines and publishing alerts?"; options = ["DEA", "FDA", "ISMP", "TJC"]; correctOptionIndex = 2; explanation = "ISMP (Institute for Safe Medication Practices) publishes safety alerts, high-alert medication lists, and error-prone abbreviation lists."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q77"; versionId = "ptcb-v3"; text = "Prepare 500 mL of a 0.9% NaCl solution using 23.4% NaCl stock. How many mL of stock are needed?"; options = ["9.2 mL", "19.2 mL", "23.4 mL", "46.8 mL"]; correctOptionIndex = 1; explanation = "C1V1 = C2V2; 23.4% x V1 = 0.9% x 500 mL; V1 = 450 / 23.4 = 19.2 mL."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q78"; versionId = "ptcb-v3"; text = "The brand name Strattera corresponds to:"; options = ["Methylphenidate", "Amphetamine salt", "Atomoxetine", "Lisdexamfetamine"]; correctOptionIndex = 2; explanation = "Atomoxetine (Strattera) is a selective norepinephrine reuptake inhibitor (SNRI) approved for ADHD. Unlike stimulants, it is not a controlled substance."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q79"; versionId = "ptcb-v3"; text = "Which of the following is a correct statement about biologic medications?"; options = ["They can always be substituted with an AB-rated generic", "They are synthesized from living organisms and may have biosimilars but not generics", "They never require REMS programs", "They have fewer side effects than small-molecule drugs"]; correctOptionIndex = 1; explanation = "Biologics are derived from living cells and are too complex for traditional generic substitution; interchangeable biosimilars are a separate FDA approval category."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q80"; versionId = "ptcb-v3"; text = "Which type of IV solution pulls fluid from cells into the bloodstream?"; options = ["Isotonic", "Hypotonic", "Hypertonic", "Colloid"]; correctOptionIndex = 2; explanation = "Hypertonic solutions (3% NaCl, D10W) have higher osmolarity than blood and draw water out of cells into the vascular space, used for cerebral edema or severe hyponatremia."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q81"; versionId = "ptcb-v3"; text = "Which of the following is a REMS program specifically for a clozapine-containing product?"; options = ["iPLEDGE", "TIRF REMS Access", "Clozapine REMS", "SHARES"]; correctOptionIndex = 2; explanation = "The Clozapine REMS program monitors for agranulocytosis (dangerous drop in white blood cells), requiring ANC monitoring before dispensing."; knowledgeDomain = #FederalRequirements; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q82"; versionId = "ptcb-v3"; text = "Which antibiotic is used for C. difficile (CDI) infections?"; options = ["Amoxicillin", "Vancomycin (oral) or fidaxomicin", "Azithromycin", "Ceftriaxone"]; correctOptionIndex = 1; explanation = "Oral vancomycin and fidaxomicin are first-line treatments for C. difficile infection. IV vancomycin is NOT effective for CDI."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q83"; versionId = "ptcb-v3"; text = "A prescription reads 'Disp: QS'. What does QS mean?"; options = ["Quick supply", "Quantity sufficient", "Quality standard", "Queue sequence"]; correctOptionIndex = 1; explanation = "QS (quantum sufficit) means 'a sufficient quantity' or 'quantity sufficient to make the prescribed amount.'"; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q84"; versionId = "ptcb-v3"; text = "Which of the following is an example of a Type B adverse drug reaction?"; options = ["Dose-dependent nausea from an antibiotic", "Anaphylaxis to penicillin", "Sedation from an antihistamine", "Constipation from an opioid"]; correctOptionIndex = 1; explanation = "Type B (bizarre) ADRs are unpredictable, not dose-related, and idiosyncratic (e.g., anaphylaxis, agranulocytosis). Type A are dose-dependent and predictable."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q85"; versionId = "ptcb-v3"; text = "Which of the following drug categories requires monitoring of serum drug levels to ensure safety and efficacy?"; options = ["Beta-blockers", "Anticonvulsants (phenytoin, valproate)", "H2 blockers", "ACE inhibitors"]; correctOptionIndex = 1; explanation = "Many anticonvulsants (phenytoin, valproate, carbamazepine) have narrow therapeutic ranges requiring regular serum level monitoring."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q86"; versionId = "ptcb-v3"; text = "Which measurement is used to express solution concentration as a ratio (e.g., 1:1000)?"; options = ["Percent weight per volume (w/v)", "Ratio strength", "Molarity", "Normality"]; correctOptionIndex = 1; explanation = "Ratio strength expresses the number of grams of solute per total volume (mL) of solution (e.g., 1:1000 = 1 g per 1000 mL)."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q87"; versionId = "ptcb-v3"; text = "A patient is prescribed levothyroxine 125 mcg. The pharmacy only has 50 mcg tablets. How many tablets per dose?"; options = ["1.5 tablets", "2 tablets", "2.5 tablets", "3 tablets"]; correctOptionIndex = 2; explanation = "125 mcg / 50 mcg per tablet = 2.5 tablets per dose."; knowledgeDomain = #OrderEntry; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q88"; versionId = "ptcb-v3"; text = "Which of the following represents the correct use of 'AD', 'AS', 'AU' in prescription ear drop notation?"; options = ["AD = left ear, AS = right ear, AU = both ears", "AD = right ear, AS = left ear, AU = both ears", "AD = both ears, AS = right ear, AU = left ear", "These are obsolete and should not be used"]; correctOptionIndex = 3; explanation = "AD (right ear), AS (left ear), AU (both ears) are on the ISMP error-prone abbreviation list. 'Right ear', 'left ear', 'both ears' should be written in full."; knowledgeDomain = #PatientSafety; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q89"; versionId = "ptcb-v3"; text = "Which of the following is a muscarinic antagonist (anticholinergic) inhaler used for COPD?"; options = ["Albuterol", "Salmeterol", "Tiotropium", "Fluticasone"]; correctOptionIndex = 2; explanation = "Tiotropium (Spiriva) is a long-acting muscarinic antagonist (LAMA) bronchodilator used for COPD maintenance therapy."; knowledgeDomain = #Medications; isScored = true });
    addQuestionIfMissing(questions, { id = "ptcb-v3-q90"; versionId = "ptcb-v3"; text = "Which DEA registration schedule must a pharmacy renew every how many years?"; options = ["1 year", "2 years", "3 years", "5 years"]; correctOptionIndex = 2; explanation = "DEA registrations for pharmacies must be renewed every 3 years to maintain authorization to handle controlled substances."; knowledgeDomain = #FederalRequirements; isScored = true });

    let sv4v5 = List.empty<ExamVersion>();
    let qv4v5 = List.empty<Question>();
    PoolV4V5.seedV4V5(sv4v5, qv4v5);
    for (q in qv4v5.values()) { addQuestionIfMissing(questions, q) };

