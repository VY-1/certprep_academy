    addQuestionIfMissing(questions, { id = "ptcb-org-0125"; versionId = "ptcb-org-v2"; text = "Which of the following situations requires pharmacist intervention?"; options = ["A patient asks the pharmacy technician where to find OTC antihistamines", "A pharmacy technician processing a prescription is not sure when the patient will return to the pharmacy", "A patient is prescribed a brand name only medication and asks if there is a less expensive alternative", "A patient asks the pharmacy technician if the pharmacy accepts Medicaid insurance"]; correctOptionIndex = 0; explanation = "The best answer is option A — A patient asks the pharmacy technician where to find OTC antihistamines. Rationale: this choice directly addresses the requirement in the question stem while the other options are incomplete or less appropriate. Option review: A: A patient asks the pharmacy technician where to find OTC antihistamines — Correct. B: A pharmacy technician processing a prescription is not sure when the patient will return to the pharmacy — Not correct. C: A patient is prescribed a brand name only medication and asks if there is a less expensive alternative — Not correct. D: A patient asks the pharmacy technician if the pharmacy accepts Medicaid insurance — Not correct. Exam tip: Read the stem carefully for qualifiers (e.g., first, best, except) and eliminate distractors that are factually true but irrelevant to the question asked."; knowledgeDomain = #Other("imported"); isScored = false });
    addQuestionIfMissing(questions, { id = "ptcb-org-0126"; versionId = "ptcb-org-v2"; text = "Methotrexate directions read: Take 7 tabs once per week. A patient with rheumatoid arthritis returns after 4 days to request a refill. The technician should:"; options = ["suggest an OTC analgesic until the refill is due.", "refill per the patient's request.", "tell the patient to return in 3 weeks for the refill.", "refer the patient to the pharmacist to discuss dosing."]; correctOptionIndex = 0; explanation = "The best answer is option A — suggest an OTC analgesic until the refill is due.. Rationale: this choice directly addresses the requirement in the question stem while the other options are incomplete or less appropriate. Option review: A: suggest an OTC analgesic until the refill is due. — Correct. B: refill per the patient's request. — Not correct. C: tell the patient to return in 3 weeks for the refill. — Not correct. D: refer the patient to the pharmacist to discuss dosing. — Not correct. Exam tip: Read the stem carefully for qualifiers (e.g., first, best, except) and eliminate distractors that are factually true but irrelevant to the question asked."; knowledgeDomain = #Other("imported"); isScored = false });
    addQuestionIfMissing(questions, { id = "ptcb-org-0127"; versionId = "ptcb-org-v2"; text = "For safety reasons the medical abbreviations q.d. and QD should not be used; instead they should be written as: PTCB Practice Exam (Questions Only) Page 32 of 85"; options = ["twice a day.", "four times a day.", "every four days.", "once a day."]; correctOptionIndex = 0; explanation = "The best answer is option A — twice a day.. Rationale: this choice directly addresses the requirement in the question stem while the other options are incomplete or less appropriate. Option review: A: twice a day. — Correct. B: four times a day. — Not correct. C: every four days. — Not correct. D: once a day. — Not correct. Exam tip: Read the stem carefully for qualifiers (e.g., first, best, except) and eliminate distractors that are factually true but irrelevant to the question asked."; knowledgeDomain = #Other("imported"); isScored = false });
