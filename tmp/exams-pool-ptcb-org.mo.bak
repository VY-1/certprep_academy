    addQuestionIfMissing(questions, { id = "ptcb-org-0151"; versionId = "ptcb-org-v2"; text = "Which of the following statements regarding the proper use of gloves is correct? PTCB Practice Exam (Questions Only) Page 38 of 85"; options = ["Hands should be washed before gloving because use of gloves does not replace handwashing", "Gloves should not be used when an individual's hands have scrapes or abrasions", "Handwashing is not necessary when gloves are being used", "When glove use is indicated, reusable gloves should be worn"]; correctOptionIndex = 0; explanation = "The best answer is option A — Hands should be washed before gloving because use of gloves does not replace handwashing. Rationale: this choice directly addresses the requirement in the question stem while the other options are incomplete or less appropriate. Option review: A: Hands should be washed before gloving because use of gloves does not replace handwashing — Correct. B: Gloves should not be used when an individual's hands have scrapes or abrasions — Not correct. C: Handwashing is not necessary when gloves are being used — Not correct. D: When glove use is indicated, reusable gloves should be worn — Not correct. Exam tip: Read the stem carefully for qualifiers (e.g., first, best, except) and eliminate distractors that are factually true but irrelevant to the question asked."; knowledgeDomain = #Other("imported"); isScored = false });
