    addQuestionIfMissing(questions, { id = "ptcb-org-0089"; versionId = "ptcb-org-v1"; text = "In order to minimize the risk of contamination by pathogens, hospital staff should:"; options = ["make all chemotherapeutic preparations under a horizontal laminar flow hood.", "follow procedures to ensure that infectious agents are handled and disposed of properly.", "dispose of bloodstained dressings in a regular trash can to be emptied daily.", "place all infected patients into reverse isolation."]; correctOptionIndex = 0; explanation = "The best answer is option A — make all chemotherapeutic preparations under a horizontal laminar flow hood.. Rationale: this choice directly addresses the requirement in the question stem while the other options are incomplete or less appropriate. Option review: A: make all chemotherapeutic preparations under a horizontal laminar flow hood. — Correct. B: follow procedures to ensure that infectious agents are handled and disposed of properly. — Not correct. C: dispose of bloodstained dressings in a regular trash can to be emptied daily. — Not correct. D: place all infected patients into reverse isolation. — Not correct. Exam tip: Read the stem carefully for qualifiers (e.g., first, best, except) and eliminate distractors that are factually true but irrelevant to the question asked."; knowledgeDomain = #Other("imported"); isScored = false });
