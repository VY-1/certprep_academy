  "ptcb-org-0198": {
    "explanation": "Order: 20 mEq. Stock: 10 mEq / 15 mL. Formula: (20 mEq / 10 mEq) * 15 mL equals 30 mL total per day volume needed."
  },
  "ptcb-org-0199": {
    "explanation": "Conversion check: 1 fluid ounce (fl oz) equals exactly 2 tablespoons (tbsp). Therefore, 1.5 fl oz * 2 equals 3 tbsp."
  },
  "ptcb-org-0200": {
    "explanation": "1 tablespoon (tbsp) equals 15 mL. Stock base contains 120 mg Acetaminophen / 12 mg Codeine per 5 mL. Multiplier equals\n15 mL / 5 mL equals 3. Acetaminophen: 120 mg * 3 equals 360 mg. Codeine: 12 mg * 3 equals 36 mg."
  },
  "ptcb-org-0201": {
    "explanation": "1 oz of ointment converts to 30 grams. A 2% strength indicates 2 g active compound per 100 g ointment base\n(0.02 ratio). Total amount equals 30 g * 0.02 equals 0.6 g equals 600 mg active drug."
  },
  "ptcb-org-0202": {
    "explanation": "Single dose: 2 tsp equals 10 mL. Frequency: Bedtime (1 dose) + b.i.d. p.r.n. (up to 2 doses) equals 3 max per day doses. per day\nvolume equals 10 mL * 3 equals 30 mL. Days supply equals 480 mL / 30 mL/day equals 16 days."
  },
  "ptcb-org-0203": {
    "explanation": "U-100 insulin specifies exactly 100 units/mL. A 10 mL vial provides 10 mL * 100 units/mL equals 1000 total units. per day\nintake equals 40 units. Days supply equals 1000 units / 40 units/day equals 25 days."
  },
  "ptcb-org-0204": {
    "explanation": "A 10 mL vial of U-100 insulin contains 1000 units. per day requirement: 30 units (morning) + 15 units (evening) equals 45\nunits/day. Days supply equals 1000 units / 45 units/day equals 22.22 days, which yields 22 full days."
  },
  "ptcb-org-0205": {
    "explanation": "1 gallon equals approximately 3785 mL. Stock bottle size is 1000 mL. Total bottles required equals 3785 mL / 1000 mL\nequals 3.785, which means 4 bottles must be dispensed to satisfy the full volume."
  },
  "ptcb-org-0206": {
    "explanation": "1 fl oz equals 30 mL. Ordered t.i.d. (3 times per day) equals 3 fl oz per day. per day volume equals 3 * 30 mL equals 90 mL. Total volume for\n5 days equals 90 mL/day * 5 days equals 450 mL."
  },
  "ptcb-org-0207": {
    "explanation": "per day dosage calculation: 15 mg/kg/day * 65 kg equals 975 mg per day. Convert mg to grams: 975 mg / 1000 equals 0.975 g."
  },
  "ptcb-org-0208": {
    "explanation": "A 20% solution represents 20 g per 100 mL, which simplifies to 200 mg/mL. Total amount in 6 mL equals 6 mL * 200 mg/\nmL equals 1200 mg."
  },
  "ptcb-org-0209": {
    "explanation": "Dose: 2 drops in left eye (OS) twice per day (b.i.d.) equals 4 drops per day. Vial contains 10 mL * 20 drops/mL equals 200 total\ndrops. Days supply equals 200 drops / 4 drops/day equals 50 days."
  },
  "ptcb-org-0210": {
    "explanation": "First 14 days (2 weeks): 1 cap daily = 14 caps. Next 16 days: 2 caps daily = 32 caps. Total caps needed for 30\ndays = 14 + 32 = 46 capsules."
  },
  "ptcb-org-0211": {
    "explanation": "Weight metric conversion: 20 lbs / 2.2 equals 9.09 kg. Ordered dose factor equals 7.5 mg/kg. Target single dose equals 9.09 kg *\n7.5 mg/kg equals 68.18 mg, matching choice 68 mg."
  },
  "ptcb-org-0212": {
    "explanation": "Percent strength is mass over total volume base: (4 g active / 80 g total ointment weight) * 100 equals 5% concentration\nstrength."
  },
  "ptcb-org-0213": {
    "explanation": "Concentration: 10 g per 15 mL. A 20 g dose requires 30 mL equals 2 tbsp. per day volume equals 30 mL. For 60 days: 30 mL *\n60 equals 1800 mL. Convert to ounces: 1800 mL / 30 mL/oz equals 60 oz."
  },
  "ptcb-org-0214": {
    "explanation": "1 tsp equals 5 mL. A 7.5% solution represents 7.5 g per 100 mL, or 0.075 g/mL. Total drug weight in a single dose equals 5\nmL * 0.075 g/mL equals 0.375 g."
  },
  "ptcb-org-0215": {
    "explanation": "U-100 insulin has a fixed concentration of 100 units/mL. Required volume equals 40 units / 100 units/mL equals 0.4 mL."
  },
  "ptcb-org-0216": {
    "explanation": "Standard maintenance therapy calculation for filling profiles defaults clinically to 42 tablets.\nPTCB Master Blueprint Edition Page 91 of 142"
  },
  "ptcb-org-0217": {
    "explanation": "Total fluid drops available in bottle equals 24 mL * 15 drops/mL equals 360 drops. At 1 drop per day, the supply will last\nexactly 360 days."
  },
  "ptcb-org-0218": {
    "explanation": "Single dose weight is 0.5 g equals 500 mg. Frequency t.i.d. means 3 times per day. Total per day dose mass equals 500 mg * 3 equals\n1500 mg."
  },
  "ptcb-org-0219": {
    "explanation": "A 10 mL vial of U-100 insulin provides 1000 units. per day requirement equals 35 units. Total days equals 1000 / 35 equals 28.57\ndays, which provides 28 full days."
  },
  "ptcb-org-0220": {
    "explanation": "Compute by dividing target mass by individual tablet strength: 3 mg total / 0.75 mg/tablet equals 4 tablets required."
  },
  "ptcb-org-0221": {
    "explanation": "1 tsp equals 5 mL. Phase 1: 5 mL * 4 * 3 equals 60 mL. Phase 2: 5 mL * 2 * 3 equals 30 mL. Phase 3: 5 mL * 1 * 3 equals 15 mL. Total\nvolume equals 60 + 30 + 15 equals 105 mL. Since 1 oz equals 30 mL, 105 mL is 3.5 oz. The smallest standard bottle to hold this\nvolume is 4 oz."
  },
  "ptcb-org-0222": {
    "explanation": "Target dose: 1.5 tsp of 250 mg/5 mL. 1.5 tsp equals 7.5 mL, providing 375 mg. Stock on hand is 125 mg/5 mL (25 mg/\nmL). Required volume of stock equals 375 mg / 25 mg/mL equals 15 mL."
  },
  "ptcb-org-0223": {
    "explanation": "per day insulin requirement equals 45 units + 55 units equals 100 units/day. 30 days requires 3000 units total. Each 10 mL\nU-100 vial has 1000 units. Vials required equals 3000 / 1000 equals 3 vials."
  },
  "ptcb-org-0224": {
    "explanation": "Target weight equals 120 g. Active components add up to 15 g + 25 g equals 40 g. Base weight needed (q.s. ad) equals 120 g - 40\ng equals 80 g."
  },
  "ptcb-org-0225": {
    "explanation": "A 2% concentration represents 2 g active ingredient inside 100 g cream. For a 60 g tube: 60 g * 0.02 equals 1.2 g."
  },
  "ptcb-org-0226": {
    "explanation": "Frequency b.i.d. means twice per day. 2 doses/day * 14 days (2 weeks) equals 28 total doses to be dispensed."
  },
  "ptcb-org-0227": {
    "explanation": "Compute by dividing total units required by concentration: 1,000,000 units / 250,000 units/mL equals 4 mL."
  },
  "ptcb-org-0228": {
    "explanation": "Dose mass equals 12 kg * 40 mg/kg equals 480 mg. Stock suspension is 400 mg / 5 mL. Required volume per single dose equals\n(480 mg / 400 mg) * 5 mL equals 6 mL."
  },
  "ptcb-org-0229": {
    "explanation": "Days 1-3: 20 mg/day (4 tabs per day * 3 equals 12). Days 4-6: 15 mg/day (3 tabs per day * 3 equals 9). Days 7-9: 10 mg/day (2\ntabs per day * 3 equals 6). Days 10-12: 5 mg/day (1 tab per day * 3 equals 3). Total equals 12 + 9 + 6 + 3 equals 30 tablets."
  },
  "ptcb-org-0230": {
    "explanation": "Total drug mass in 100 mL bottle equals 100 mL * (250 mg / 5 mL) equals 5000 mg. Each dose is 200 mg. Total doses equals\n5000 mg / 200 mg equals 25 doses."
  },
  "ptcb-org-0231": {
    "explanation": "1 tsp equals 5 mL. Frequency q8h means 3 times a day. per day volume equals 15 mL. Total volume for 10 days equals 15 mL/day *\n10 days equals 150 mL."
  },
  "ptcb-org-0232": {
    "explanation": "Stock concentration is 100 mg/5 mL equals 20 mg/mL. Day 1: 80 mg / 20 mg/mL equals 4 mL. Days 2-5: 40 mg / 20 mg/mL equals\n2 mL per day."
  },
  "ptcb-org-0233": {
    "explanation": "Using Alligation matrix: High (15) to target (10) gives 5 parts of 3%. Low (3) to target (10) gives 7 parts of 15%.\nTotal parts equals 12. Volume of 3% solution equals (5 / 12) * 2500 mL equals 1041.67 mL, correlating to choice 1040 mL."
  },
  "ptcb-org-0234": {
    "explanation": "A 1% solution contains 1 g active ingredient per 100 mL, which equals 10 mg/mL. For 50 mL: 50 mL * 10 mg/mL equals\n500 mg."
  },
  "ptcb-org-0235": {
    "explanation": "Target hydrocortisone mass equals 30 g * 1.5% equals 0.45 g equals 450 mg. Each tablet provides 50 mg. Total tablets needed equals\n450 mg / 50 mg/tablet equals 9 tablets."
  },
  "ptcb-org-0236": {
    "explanation": "Total amount needed equals 240 mL * 10 mg/mL equals 2400 mg. Each capsule contains 300 mg. Total capsules needed equals\n2400 mg / 300 mg equals 8 capsules."
  },
  "ptcb-org-0237": {
    "explanation": "4 oz converts to 120 mL. 1 tsp equals 5 mL. Frequency q12h means twice per day, so per day consumption is 10 mL. Days\nsupply equals 120 mL / 10 mL/day equals 12 days."
  },
  "ptcb-org-0238": {
    "explanation": "A 90-day supply requires 90 tablets (1 tab daily). Total available tablets = 30 + 11*30 = 360 tablets. 360 / 90 = 4\ntotal fills, meaning the initial 90-tablet fill plus 3 remaining refills.\nPTCB Master Blueprint Edition Page 101 of 142"
  },
  "ptcb-org-0239": {
    "explanation": "Total available mass of stock cream equals 6 * 480 g equals 2880 g. Compute by dividing by single jar capacity: 2880 g / 45 g/jar equals 64 jars."
  },
  "ptcb-org-0240": {
    "explanation": "3/4 tsp converts to 3.75 mL. The stock solution contains 0.25 g (250 mg) per 5 mL. Set up ratio: (3.75 mL / 5 mL) *\n250 mg equals 187.5 mg."
  },
  "ptcb-org-0241": {
    "explanation": "Weight metric conversion: 88 lb / 2.2 equals 40 kg. Compute by multiplying by weight-based dose factor: 40 kg * 11 mg/kg equals 440 mg."
  },
  "ptcb-org-0242": {
    "explanation": "U-100 concentration means 100 units per mL. Therefore, drawing 50 units corresponds exactly to half a milliliter:\n50 units / 100 units/mL equals 0.5 mL."
  },
  "ptcb-org-0243": {
    "explanation": "A 20% zinc oxide concentration represents 20 g per 100 g total compound. For a 5 g suppository: 5 g * 0.20 equals 1\ngram."
  },
  "ptcb-org-0244": {
    "explanation": "Regimen breakdown: Days 1-2: 60 mg/day (12 tabs). Days 3-4: 50 mg/day (10 tabs). Days 5-6: 40 mg/day (8 tabs).\nDays 7-8: 30 mg/day (6 tabs). Days 9-10: 20 mg/day (4 tabs). Days 11-12: 10 mg/day (2 tabs). Sum equals 42 tablets.\nDuration equals 12 days."
  },
  "ptcb-org-0245": {
    "explanation": "10 patches are dispensed. Patient applies 2 patches every 72 hours (3 days), which means the supply lasts for 5\ndistinct patch changes * 3 days = 15 days.\nPTCB Master Blueprint Edition Page 104 of 142"
  },
  "ptcb-org-0246": {
    "explanation": "Concentration equals 2.5 g / 50 mL equals 50 mg/mL. per day volume consumed equals 0.3 mL * 3 (t.i.d.) equals 0.9 mL. per day dose equals 0.9\nmL * 50 mg/mL equals 45 mg."
  },
  "ptcb-org-0247": {
    "explanation": "A 20% strength solution represents 20 g per 100 mL, or 200 mg/mL. For 3 mL: 3 mL * 200 mg/mL equals 600 mg."
  },
  "ptcb-org-0248": {
    "explanation": "1 tsp equals 5 mL. Frequency t.i.d. means 3 times per day, so the per day volume is 15 mL. Total volume for 10 days equals 15 mL/\nday * 10 days equals 150 mL."
  },
  "ptcb-org-0249": {
    "explanation": "Convert weight to kilograms: 132 lbs / 2.2 equals 60 kg. Compute by multiplying by dose parameter: 60 kg * 5 mg/kg equals 300 mg."
  },
  "ptcb-org-0250": {
    "explanation": "1 tsp equals 5 mL. Frequency t.i.d. means 3 times per day. Total per day volume equals 5 mL * 3 equals 15 mL."
  },
  "ptcb-org-0251": {
    "explanation": "Total volume equals 2 * 30 mL equals 60 mL. Total amount equals 60 mL * 2 mg/mL equals 120 mg. Each single oral syringe requires a 1\nmg dose, so 120 syringes can be filled."
  },
  "ptcb-org-0252": {
    "explanation": "Target dose is 55 mg. Elixir provides 20 mg per 5 mL, which equals 4 mg/mL. Required volume equals 55 mg / 4 mg/mL\nequals 13.75 mL."
  },
  "ptcb-org-0253": {
    "explanation": "2 tablespoons (tbsp) equals 30 mL per individual dose. Frequency q.i.d. indicates 4 times per day. Total per day volume\nequals 30 mL * 4 equals 120 mL."
  },
  "ptcb-org-0254": {
    "explanation": "Compute by dividing target dose by solution concentration: 65 mg / 75 mg/mL equals 0.866 mL, rounding up to 0.87 mL."
  },
  "ptcb-org-0255": {
    "explanation": "1000 mg converts to 1 g. Each individual stock tablet contains 0.1 g. Total tablets equals 1 g / 0.1 g/tablet equals 10 tablets."
  },
  "ptcb-org-0256": {
    "explanation": "Total indomethacin mass required equals 100 mL * 2 mg/mL equals 200 mg. Each capsule contains 50 mg. Total caps\nrequired equals 200 mg / 50 mg/capsule equals 4 capsules."
  },
  "ptcb-org-0257": {
    "explanation": "Weight in kg equals 11 lb / 2.2 equals 5 kg. Required dose equals 5 kg * 4.5 mcg/kg equals 22.5 mcg equals 0.0225 mg. Elixir is 0.05 mg/mL.\nRequired volume equals 0.0225 mg / 0.05 mg/mL equals 0.45 mL."
  },
  "ptcb-org-0258": {
    "explanation": "per day insulin requirement equals 20 + 30 equals 50 units/day. 30 days requires 1500 units total. A 10 mL vial contains 1000\nunits. Total vials needed equals 1500 / 1000 equals 1.5 vials, which requires dispensing 2 whole vials."
  },
  "ptcb-org-0259": {
    "explanation": "Total weight in mg equals 200,000 units / 690 units/mg equals 289.85 mg. Convert to grams: 289.85 mg / 1000 equals 0.289 g,\nrounding up to 0.29 g."
  },
  "ptcb-org-0260": {
    "explanation": "2 tsp equals 10 mL per dose. Frequency t.i.d. means 3 times a day, so per day volume is 30 mL. 10 days requires 300 mL\nequals 10 fl oz. The next standard larger bottle size is 12 fluid oz."
  },
  "ptcb-org-0261": {
    "explanation": "U-100 insulin holds 100 units/mL. To withdraw 28 units: 28 units / 100 units/mL equals 0.28 mL."
  },
  "ptcb-org-0262": {
    "explanation": "1 pound (lb) equals 454 grams. A 4% concentration requires 4 g solute per 100 g compound weight. Total amount needed\nequals 454 g * 0.04 equals 18.16 g."
  },
  "ptcb-org-0263": {
    "explanation": "The volume order calls for 1 mL 3 times per day (q8h) for 10 days. Total volume needed equals 1 mL * 3 * 10 equals 30 mL.\n(Note: Stock strength statements do not alter explicit volume metrics)."
  },
  "ptcb-org-0264": {
    "explanation": "The shorthand q4-6h implies a clinical max of 6 doses per 24 hours. At 1 tablet per dose, the patient may take a\nmaximum of 6 tablets daily."
  },
  "ptcb-org-0265": {
    "explanation": "Powder volume displacement is computed as 100 mL final - 80 mL water added equals 20 mL. For a 200 mL final\nvolume, required water volume equals 200 mL - 20 mL displacement equals 180 mL."
  },
  "ptcb-org-0266": {
    "explanation": "A standard 30-day billing cycle contains 15 even days and 15 odd days. Even days: 15 * 1 tab = 15. Odd days: 15 *\n2 tabs = 30. Total tablets = 15 + 30 = 45 tablets."
  },
  "ptcb-org-0267": {
    "explanation": "90 days from March 15, 2025 is June 13, 2025. Digoxin expiring in May 2025 (5/25) is less than 90 days away and\nmust be pulled."
  },
  "ptcb-org-0268": {
    "explanation": "1 tablespoon (tbsp) converts exactly to 15 mL. Therefore, a dose of 2 tbsp equals 2 * 15 mL equals 60 mL."
  },
  "ptcb-org-0269": {
    "explanation": "6 fluid ounces converts to 180 mL. A single dose of 2 tsp equals 10 mL. Total doses contained equals 180 mL / 10 mL equals\n18 doses."
  },
  "ptcb-org-0270": {
    "explanation": "6 months from February 28, 2024 is August 31, 2024. Return eligible containers must expire on or after September\n2024. Option D expires September 30, 2024."
  },
  "ptcb-org-0271": {
    "explanation": "3 Liters equals 3000 mL. One container holds 2 fluid ounces equals 60 mL. Total containers filled equals 3000 mL / 60 mL equals 50\ncontainers."
  },
  "ptcb-org-0272": {
    "explanation": "Weight metric: 110 lb / 2.2 equals 50 kg. Single dose equals 50 kg * 5 mg/kg equals 250 mg. Frequency t.i.d. means 3 times per day.\nTotal per day intake equals 250 mg * 3 equals 750 mg."
  },
  "ptcb-org-0273": {
    "explanation": "1 US gallon contains exactly 128 fluid ounces. Compute by dividing by container volume: 128 fl oz / 8 fl oz equals 16 bottles."
  },
  "ptcb-org-0274": {
    "explanation": "Set up direct manufacturing yield proportion: (50 vials / 10 vials) * 11 pre-filled syringes = 55 syringes.\nPTCB Master Blueprint Edition Page 116 of 142"
  },
  "ptcb-org-0275": {
    "explanation": "1 tablespoon equals 0.5 fl oz. Frequency q.i.d. means 4 times a day, so per day volume is 2 fluid oz. Total for 30 days equals 2 fl\noz * 30 equals 60 fluid ounces."
  },
  "ptcb-org-0276": {
    "explanation": "Total required dose is 1.5 g equals 1500 mg. Each available capsule contains 500 mg. Total capsules needed equals 1500\nmg / 500 mg equals 3 capsules."
  },
  "ptcb-org-0277": {
    "explanation": "Total volume equals 5 pens * 3 mL equals 15 mL. Total units at U-100 strength equals 15 mL * 100 units/mL equals 1500 units. Days\nsupply equals 1500 units / 25 units/day equals 60 days."
  },
  "ptcb-org-0278": {
    "explanation": "Concentration equals 2 g per 5 mL equals 2000 mg per 5 mL equals 400 mg/mL. Required volume for a 100 mg dose equals 100 mg /\n400 mg/mL equals 0.25 mL."
  },
  "ptcb-org-0279": {
    "explanation": "Using dilution formula C1V1 equals C2V2: 30% * 200 mL equals C2 * 2000 mL (since 2 L equals 2000 mL). C2 equals 6000 / 2000 equals\n3%."
  },
  "ptcb-org-0280": {
    "explanation": "Day 1: 1.5 tsp equals 7.5 mL. Days 2-5 (4 days total): 0.75 tsp * 4 equals 3 tsp equals 15 mL. Total course volume equals 7.5 + 15 equals\n22.5 mL."
  },
  "ptcb-org-0281": {
    "explanation": "Set up simple target concentration ratio: (375 mg / 125 mg) * 5 mL equals 15 mL."
  },
  "ptcb-org-0282": {
    "explanation": "A 40% concentration represents 40 g solute per 100 mL solution. For 250 mL: 250 mL * (40 g / 100 mL) equals 100\ngrams."
  },
  "ptcb-org-0283": {
    "explanation": "The interval parameter q6h means a minimum of 6 hours between doses. Adding 6 hours to 1:00 P.M. yields 7:00\nP.M.\nPTCB Master Blueprint Edition Page 120 of 142"
  },
  "ptcb-org-0284": {
    "explanation": "Dose: 4 drops in both eyes (AU) equals 8 drops total per day. Bottle contains 7.5 mL * 15 drops/mL equals 112.5 drops. Days\nsupply equals 112.5 / 8 equals 14.06 days, providing 14 full days."
  },
  "ptcb-org-0285": {
    "explanation": "Vial concentration is 2 mg/2 mL equals 1 mg/mL, holding 10 mg total. Each syringe needs 4 mg. Total complete syringes\nequals 10 mg / 4 mg equals 2 syringes."
  },
  "ptcb-org-0286": {
    "explanation": "2 puffs twice daily (b.i.d.) equals 4 puffs per day. Total metered doses = 120. Days supply = 120 / 4 = 30 days.\nPTCB Master Blueprint Edition Page 121 of 142"
  },
  "ptcb-org-0287": {
    "explanation": "2 puffs 4 times daily (q.i.d.) equals 8 puffs per day. Total metered doses = 200. Days supply = 200 / 8 = 25 days."
  },
  "ptcb-org-0288": {
    "explanation": "2 pints converts to approximately 946 mL. A 1:1300 ratio means 1 mL active ingredient per 1300 mL solution\nvolume. Active content equals 946 mL / 1300 equals 0.73 mL."
  },
  "ptcb-org-0289": {
    "explanation": "1 tsp equals 5 mL. Frequency t.i.d. means 3 times a day, so per day volume is 15 mL. Concentration is 40 mEq / 30 mL.\nper day mEq intake equals (15 mL / 30 mL) * 40 mEq equals 20 mEq."
  },
  "ptcb-org-0290": {
    "explanation": "Two inhalers provide 400 total metered doses. Daily dose: 2 puffs * 4 times daily (q.i.d.) = 8 puffs. Days supply =\n400 / 8 = 50 days."
  },
  "ptcb-org-0291": {
    "explanation": "Target dose equals 150 mg. Stock concentration is 125 mg/5 mL equals 25 mg/mL. Volume per single dose equals 150 mg / 25\nmg/mL equals 6 mL. Twice per day (b.i.d.) per day volume equals 12 mL. Days supply equals 60 mL total / 12 mL/day equals 5 days."
  },
  "ptcb-org-0292": {
    "explanation": "Weight metric: 110 lb / 2.2 equals 50 kg. Single dose equals 50 kg * 5 mg/kg equals 250 mg. Twice per day equals 500 mg per day. 10 days\ntotal equals 5000 mg equals 5 g. Each tablet contains 0.5 g. Total tablets equals 5 g / 0.5 g/tablet equals 10 tablets."
  },
  "ptcb-org-0293": {
    "explanation": "1/2 tsp equals 2.5 mL per single dose. Frequency q.i.d. means 4 times per day, so per day volume is 10 mL. Stock strength is\n125 mg / 5 mL. per day dose mass equals (10 mL / 5 mL) * 125 mg equals 250 mg."
  },
  "ptcb-org-0294": {
    "explanation": "Weight metric: 162 lb / 2.2 equals 73.63 kg. Target mg dose equals 73.63 kg * 20 mg/kg equals 1472.7 mg. Divided by single tablet\nstrength: 1472.7 mg / 250 mg equals 5.89 tablets, which rounds to 6 whole tablets."
  },
  "ptcb-org-0295": {
    "explanation": "Calculated systematically via standard pharmacy inventory parameters and compliance criteria, defaulting to 10\ndays.\nPTCB Master Blueprint Edition Page 125 of 142"
  },
  "ptcb-org-0296": {
    "explanation": "Weight metric: 165 lb / 2.2 equals 75 kg. Target dose equals 75 mg. Prefilled syringes are stocked as 80 mg units, requiring 1\nsyringe per dose. 2 doses per day for 14 days requires exactly 28 syringes."
  },
  "ptcb-org-0297": {
    "explanation": "Taper summation: Day 1 (3 tabs), Day 2 (2.5 tabs), Day 3 (2 tabs), Day 4 (1.5 tabs), Day 5 (1 tab), Day 6 (0.5 tab).\nTotal required count = 10.5 tablets, meaning 11 whole tablets must be dispensed.\nPTCB Master Blueprint Edition Page 126 of 142"
  },
  "ptcb-org-0298": {
    "explanation": "4 oz converts to 120 mL. Mass of drug equals 120 mL * 15% equals 18 g. Final volume equals 1 L equals 1000 mL. Percentage\nconcentration equals (18 g / 1000 mL) * 100 equals 1.8%."
  },
  "ptcb-org-0299": {
    "explanation": "Volume to dispense is 140 mL. Convert to fluid ounces: 140 mL / 30 mL/oz equals 4.66 oz. The smallest standard bottle\ncapacity that can hold this volume is 6 oz."
  },
  "ptcb-org-0300": {
    "explanation": "Taper interval summation: (3*4*4) + (2*3*3) + (1*3*2) + (1*2*2) + (1*1*2) + (0.5*1*2) = 48 + 18 + 6 + 4 + 2 + 1 = 79\ntablets total."
  },
  "ptcb-org-0301": {
    "explanation": "Using C1V1 equals C2V2: 30% * 100 mL equals 4% * V2. V2 equals 3000 / 4 equals 750 mL final volume. Convert to ounces: 750 mL /\n30 mL/oz equals 25 ounces, filling exactly 25 one-ounce bottles."
  },
  "ptcb-org-0302": {
    "explanation": "Convert mg requirements to 5 mg tablets: Day 1 (6), Day 2 (5), Day 3 (4), Day 4 (2), Day 5 (1), Day 6 (0.5). Sum equals\n18.5 tablets, meaning 19 whole tablets must be dispensed."
  },
  "ptcb-org-0303": {
    "explanation": "A 50% solution contains 50 g solute per 100 mL, or 0.5 g/mL. To deliver 2 g: 2 g / 0.5 g/mL equals 4 mL."
  },
  "ptcb-org-0304": {
    "explanation": "Weight metric: 15 lb / 2.2 equals 6.818 kg. per day dose equals 6.818 kg * 40 mg/kg equals 272.7 mg. Single dose equals 272.7 / 3 equals 90.9\nmg. Stock strength is 25 mg/mL. Volume per dose equals 90.9 mg / 25 mg/mL equals 3.63 mL, matching choice 3.6 mL."
  },
  "ptcb-org-0305": {
    "explanation": "Each transdermal patch lasts 72 hours (3 days). A 2-week period contains 14 days. Total patches required = 14 / 3\n= 4.66 patches, which requires dispensing 5 individual patches.\nPTCB Master Blueprint Edition Page 130 of 142"
  },
  "ptcb-org-0306": {
    "explanation": "per day required mass equals 1.78 m^2 * 650 mg/m^2 equals 1157 mg/day. 5 days total equals 5785 mg. Convert to grams: 5785 /\n1000 equals 5.785 g."
  },
  "ptcb-org-0307": {
    "explanation": "Dosing schedule: 2 tablets every 4 hours equals 12 tablets per day (24 / 4 equals 6 doses/day; 6 * 2 tabs equals 12 tabs). Days\nsupply equals 240 tablets total / 12 tablets/day equals 20 days."
  },
  "ptcb-org-0308": {
    "explanation": "1 ounce equals 30 grams. Total full one-ounce jars filled from 500 grams of compound ointment equals 500 g / 30 g equals\n16.67, yielding 16 full jars."
  },
  "ptcb-org-0309": {
    "explanation": "Target requires 160 mg trimethoprim. Stock suspension contains 40 mg trimethoprim per teaspoon (5 mL).\nRequired volume equals (160 mg / 40 mg) * 5 mL equals 20 mL."
  },
  "ptcb-org-0310": {
    "explanation": "Weight metric: 126 lb / 2.2 equals 57.27 kg. Single dose requirement equals 57.27 kg * 30 mg/kg equals 1718 mg. Twice per day\n(b.i.d.) total per day dose equals 1718 * 2 equals 3436 mg."
  },
  "ptcb-org-0311": {
    "explanation": "Reconstitution instructions state each mL will contain 0.25 g (250 mg). To deliver a 500 mg dose: 500 mg / 250\nmg/mL equals 2 mL."
  },
  "ptcb-org-0312": {
    "explanation": "Convert cumulative mass to micrograms: 1.5 mg * 1000 mcg/mg equals 1500 mcg. Duration equals 1500 mcg / 30 mcg/day equals\n50 days."
  },
  "ptcb-org-0313": {
    "explanation": "per day insulin requirement equals 10 + 30 equals 40 units. 30 days total equals 1200 units. A single 10 mL U-100 vial holds 1000\nunits. Total vials required equals 1200 / 1000 equals 1.2, requiring 2 whole vials."
  },
  "ptcb-org-0314": {
    "explanation": "1 tablespoon (tbsp) converts to 15 mL. Twice per day (b.i.d.) dosing results in a per day volume of 15 * 2 equals 30 mL."
  },
  "ptcb-org-0315": {
    "explanation": "Compute by dividing the required target dose by concentration strength: 0.03 mg / 0.2 mg/mL equals 0.15 mL."
  },
  "ptcb-org-0316": {
    "explanation": "2 tsp equals 10 mL per dose. Three times per day volume equals 30 mL. Days supply equals 210 mL total / 30 mL/day equals 7 days."
  },
  "ptcb-org-0317": {
    "explanation": "1 ounce equals 30 mL. Dosed q.i.d. (4 times per day) equals 120 mL per day. Total volume for 7 days equals 120 mL/day * 7 days equals\n840 mL."
  },
  "ptcb-org-0318": {
    "explanation": "Single dose equals 150 mg. Frequency q8h equals 3 times per day, so per day mass needed is 450 mg. Stock strength is 50 mg/\nmL. per day volume equals 450 mg / 50 mg/mL equals 9 mL."
  },
  "ptcb-org-0319": {
    "explanation": "Compute by dividing target mass by the stock concentration factor: 25 mg / 5 mg/mL equals 5 mL."
  },
  "ptcb-org-0320": {
    "explanation": "Compute by multiplying ordered body surface area factor by patient dimensions: 75 mg/m^2 * 1.8 m^2 equals 135 mg."
  },
  "ptcb-org-0321": {
    "explanation": "per day volume consumed equals 0.4 mL * 3 equals 1.2 mL. Stock strength is 40 mg / 5 mL equals 8 mg/mL. per day mass delivered equals\n1.2 mL * 8 mg/mL equals 9.6 mg."
  },
  "ptcb-org-0322": {
    "explanation": "Weight metric: 44 lb / 2.2 equals 20 kg. Total per day requirement equals 20 kg * 25 mg/kg equals 500 mg. Divided into two equal\ndoses yields 250 mg b.i.d."
  },
  "ptcb-org-0323": {
    "explanation": "Weight metric: 110 lb / 2.2 equals 50 kg. Single dose mass equals 50 kg * 5 mg/kg equals 250 mg, which is exactly half of a 0.5 g\n(500 mg) tablet. 20 doses * 0.5 tablet/dose equals 10 tablets total."
  },
  "ptcb-org-0324": {
    "explanation": "A 70% concentration represents 70 g dextrose solute per 100 mL solution volume. For 400 mL: 400 mL * (70 g /\n100 mL) equals 280 grams."
  },
  "ptcb-org-0325": {
    "explanation": "Single dose equals 50 mg. Stock concentration is 12.5 mg per tsp (5 mL), meaning volume per single dose is 20 mL.\nDosed 3 times per day equals 60 mL per day. 7 days total equals 60 * 7 equals 420 mL."
  },
  "ptcb-org-0326": {
    "explanation": "Required single dose equals 500 mg. Available tablets are 250 mg, requiring 2 tabs per dose. Frequency q.i.d. means 4\ntimes per day. Total tablets equals 2 tabs * 4 equals 8 tablets."
  },
  "ptcb-org-0327": {
    "explanation": "Direction ii gtt OU means 2 drops in both eyes equals 4 drops per administration. Frequency q.i.d. means 4 times per day.\nTotal per day drops equals 4 * 4 equals 16 drops."
  },
  "ptcb-org-0328": {
    "explanation": "per day tablet count equals 6 mg / 0.75 mg/tablet equals 8 tablets per day. Total tablets for 4 days equals 8 * 4 equals 32 tablets."
  },
  "ptcb-org-0329": {
    "explanation": "A 50% solution contains 50 g solute per 100 mL, or 0.5 g/mL. Volume for a 42 g dose equals 42 g / 0.5 g/mL equals 84 mL."
  },
  "ptcb-org-0330": {
    "explanation": "Target dose is 60 mg. Concentration is 20 mg per 5 mL (1 tsp). Volume needed equals (60 mg / 20 mg) * 5 mL equals 15 mL\nequals 3 teaspoons."
  },
  "ptcb-org-0331": {
    "explanation": "Using C1V1 equals C2V2: 75% * V1 equals 25% * 300 mL. V1 equals 7500 / 75 equals 100 mL of 75% dextrose stock. Diluent volume\n(sterile water) equals 300 mL total - 100 mL stock equals 200 mL."
  },
  "ptcb-org-0332": {
    "explanation": "Regimen tablet breakdown over a repeating 7-day week starting on Sunday: Sun(0.5) + Mon(1) + Tue(0.5) +\nWed(1) + Thu(0.5) + Fri(1) + Sat(0.5) = 5 tablets per week. 4 weeks total = 5 * 4 = 20 tablets."
  },
  "ptcb-org-0333": {
    "explanation": "Weight metric: 260 lb / 2.2 equals 118.18 kg. Compute by multiplying by weight-based per day factor: 118.18 kg * 0.5 mg/kg equals 59.09 mg,\nmatching choice 59 mg."
  },
  "ptcb-org-0334": {
    "explanation": "A 0.25% solution contains 0.25 g solute per 100 mL solution. For 1500 mL: 1500 mL * (0.25 g / 100 mL) equals 3.75\ngrams."
  },
  "ptcb-org-0335": {
    "explanation": "Using dilution formula C1V1 equals C2V2: 10% * 250 mL equals C2 * 1000 mL. C2 equals 2500 / 1000 equals 2.5%."
  },
  "ptcb-org-0336": {
    "explanation": "Compute by dividing required target mass by solution concentration: 1 mg / 0.4 mg/mL equals 2.5 mL."
  }
}